<record id="email_template_factura_ticket" model="mail.template">
    <field name="name">Envío de Factura Electrónica</field>
    <field name="model_id" ref="contabilidad_kuale.model_contabilidad_kuale_ticket_monitor"/>
    <field name="subject">Factura {{ object.ticket_folio }} - {{ object.company_id.name }}</field>
    <field name="email_from">{{ object.company_id.email }}</field>
    <field name="body_html" type="html">
        <div style="font-family: 'Montserrat', sans-serif;">
            <p>Hola,</p>
            <p>Adjunto a este correo encontrarás los archivos (PDF y XML) de tu factura correspondiente al ticket <strong>{{ object.ticket_folio }}</strong>.</p>
            <p>Monto total: <strong>{{ object.total }}</strong></p>
            <br/>
            <p>Gracias por tu preferencia.</p>
        </div>
    </field>
</record>