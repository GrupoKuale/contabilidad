<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">

  <t t-name="kuale_income_statement.Renderer">
    <style>
      .child-row { display: none; background-color: #F3F6FB; }
      .calc-row  { background: #f6f6f6; font-weight: 600; }
      .spacer-row td { border: 0 !important; height: 8px; }
      .k-toggle-icon { display:inline-block; width:18px; }
    </style>

      <header>
            <div class="ms-auto d-flex gap-2">
              <button class="btn btn-sm btn-primary" t-on-click="exportToExcel">
                <i class="fa fa-file-excel-o me-1"/>
                  Exportar a Excel
              </button>
              <button class="btn btn-sm btn-secondary" t-on-click="exportToPDF">
                <i class="fa fa-file-pdf-o me-1"/>
                  Guardar PDF
              </button>
            </div>
        </header>

      <!-- Filtros -->
      <div class="mb-3 d-flex align-items-end gap-3 flex-wrap">
      <div>
        <label class="form-label mb-1">Compañía:</label>
          <select class="form-select form-select-sm" t-on-change="onCompanyChange">
          <t t-foreach="state.companyList" t-as="c" t-key="c.id">
            <option t-att-value="c.id" t-att-selected="state.selectedCompanyId === c.id">
              <t t-esc="c.name"/>
            </option>
          </t>
        </select>
      </div>

      <div>
        <label class="form-label mb-1">Sucursal:</label>
          <select class="form-select form-select-sm" t-on-change="onBranchChange">
          <t t-foreach="state.branchList" t-as="branch" t-key="branch.id or 'all'">
            <option t-att-value="branch.id" t-att-selected="state.selectedBranchId === branch.id">
              <t t-esc="branch.name"/>
            </option>
          </t>
        </select>
      </div>

          <div class="form-check mt-4">
        <input class="form-check-input" type="checkbox" id="incEmpty"
               t-att-checked="state.includeEmpty ? 'checked' : null"
               t-on-change="onIncludeEmptyToggle"/>
              <label class="form-check-label" for="incEmpty">Incluir grupos/cuentas sin movimientos</label>
      </div>

          <div>
        <label class="form-label mb-1">Desde:</label>
              <input type="date" class="form-control form-control-sm"
                     t-model="state.fromDate" t-on-change="onDateChange"/>
      </div>
          <div>
        <label class="form-label mb-1">Hasta:</label>
              <input type="date" class="form-control form-control-sm"
                     t-model="state.toDate" t-on-change="onDateChange"/>
      </div>
    </div>

      <!-- Tabla -->
      <table class="table table-sm align-middle" style="margin-bottom: 50px !important;">
      <thead>
        <tr>
          <th style="width:14%">Código</th>
            <th>Descripción</th>
            <th class="text-end" style="width:16%">Periodo</th>
            <th class="text-end" style="width:9%">%</th>
            <th class="text-end" style="width:16%">Acumulado</th>
            <th class="text-end" style="width:9%">%</th>
        </tr>
      </thead>

          <tbody>
        <t t-if="props.model.state.mx">
          <!-- 2.1 -->
            <t t-if="props.model.state.mx.g21">
            <t t-call="kuale_income_statement.GroupRow">
              <t t-set="group" t-value="props.model.state.mx.g21"/>
                <!-- base para %: el propio grupo (100%) -->
                <t t-set="pbase" t-value="props.model.state.mx.g21.period_total"/>
                <t t-set="ybase" t-value="props.model.state.mx.g21.ytd_total"/>
                <t t-set="level" t-value="0"/>
            </t>
          </t>

            <!-- 2.2.1 -->
            <t t-if="props.model.state.mx.g221">
            <t t-call="kuale_income_statement.GroupRow">
              <t t-set="group" t-value="props.model.state.mx.g221"/>
                <!-- como no mostramos 2.2, fijamos base a sí mismo (100%) en nivel raíz -->
                <t t-set="pbase" t-value="props.model.state.mx.g221.period_total"/>
                <t t-set="ybase" t-value="props.model.state.mx.g221.ytd_total"/>
                <t t-set="level" t-value="0"/>
            </t>
          </t>

            <!-- Utilidad bruta -->
            <tr class="calc-row">
            <td></td>
                <td>Utilidad bruta (2.1 − 2.2.1)</td>
                <td class="text-end">
              <t t-esc="fmt(props.model.state.mx.utilidadBruta_p)"/>
            </td>
                <td class="text-end">
              <t t-esc="pct(props.model.state.mx.utilidadBruta_p, props.model.state.mx.baseP)"/>
            </td>
                <td class="text-end">
              <t t-esc="fmt(props.model.state.mx.utilidadBruta_y)"/>
            </td>
                <td class="text-end">
              <t t-esc="pct(props.model.state.mx.utilidadBruta_y, props.model.state.mx.baseY)"/>
            </td>
          </tr>
            <tr class="spacer-row"><td colspan="6"></td></tr>

            <!-- 2.2.2 -->
            <t t-if="props.model.state.mx.g222">
            <t t-call="kuale_income_statement.GroupRow">
              <t t-set="group" t-value="props.model.state.mx.g222"/>
                <!-- raíz visual: 100% -->
                <t t-set="pbase" t-value="props.model.state.mx.g222.period_total"/>
                <t t-set="ybase" t-value="props.model.state.mx.g222.ytd_total"/>
                <t t-set="level" t-value="0"/>
            </t>
          </t>

            <!-- Total de gastos generales -->
            <tr class="calc-row">
            <td></td>
                <td>Total de gastos generales (2.2.2.1 + 2.2.2.2 + 2.2.2.3)</td>
                <td class="text-end"><t t-esc="fmt(props.model.state.mx.gastosGenerales_p)"/></td>
                <td class="text-end"><t t-esc="pct(props.model.state.mx.gastosGenerales_p, props.model.state.mx.baseP)"/></td>
                <td class="text-end"><t t-esc="fmt(props.model.state.mx.gastosGenerales_y)"/></td>
                <td class="text-end"><t t-esc="pct(props.model.state.mx.gastosGenerales_y, props.model.state.mx.baseY)"/></td>
          </tr>

            <!-- Utilidad de operación -->
            <tr class="calc-row">
            <td></td>
                <td>Utilidad de operación (Utilidad bruta − Total de gastos generales)</td>
                <td class="text-end"><t t-esc="fmt(props.model.state.mx.utilidadOp_p)"/></td>
                <td class="text-end"><t t-esc="pct(props.model.state.mx.utilidadOp_p, props.model.state.mx.baseP)"/></td>
                <td class="text-end"><t t-esc="fmt(props.model.state.mx.utilidadOp_y)"/></td>
                <td class="text-end"><t t-esc="pct(props.model.state.mx.utilidadOp_y, props.model.state.mx.baseY)"/></td>
          </tr>
            <tr class="spacer-row"><td colspan="6"></td></tr>

            <!-- 2.3 -->
            <t t-if="props.model.state.mx.g23">
            <t t-call="kuale_income_statement.GroupRow">
              <t t-set="group" t-value="props.model.state.mx.g23"/>
                <t t-set="pbase" t-value="props.model.state.mx.g23.period_total"/>
                <t t-set="ybase" t-value="props.model.state.mx.g23.ytd_total"/>
                <t t-set="level" t-value="0"/>
            </t>
          </t>

            <!-- Utilidad de operación después de otros ingresos y gastos -->
            <tr class="calc-row">
            <td></td>
                <td>Utilidad de operación después de otros ingresos y gastos (− total 2.3)</td>
                <td class="text-end"><t t-esc="fmt(props.model.state.mx.uoDespuesOtros_p)"/></td>
                <td class="text-end"><t t-esc="pct(props.model.state.mx.uoDespuesOtros_p, props.model.state.mx.baseP)"/></td>
                <td class="text-end"><t t-esc="fmt(props.model.state.mx.uoDespuesOtros_y)"/></td>
                <td class="text-end"><t t-esc="pct(props.model.state.mx.uoDespuesOtros_y, props.model.state.mx.baseY)"/></td>
          </tr>
            <tr class="spacer-row"><td colspan="6"></td></tr>

            <!-- 2.n (4..9) -->
            <t t-foreach="props.model.state.mx.afterNodes" t-as="gx" t-key="gx.id">
            <t t-call="kuale_income_statement.GroupRow">
              <t t-set="group" t-value="gx"/>
                <t t-set="pbase" t-value="gx.period_total"/>
                <t t-set="ybase" t-value="gx.ytd_total"/>
                <t t-set="level" t-value="0"/>
            </t>
                <tr class="calc-row">
              <td></td>
                    <td>
                <t t-esc="'Utilidad o pérdida de '"/>
                        <t t-esc="gx.name or gx.code_prefix_start"/>
                        <t t-esc="' ('"/>
                        <t t-esc="gx.code_prefix_start"/>
                        <t t-esc="')'"/>
              </td>
                    <td class="text-end">
                <t t-esc="fmt(props.model.state.mx.otherCalcs[gx.code_prefix_start].p)"/>
              </td>
                    <td class="text-end">
                <t t-esc="pct(props.model.state.mx.otherCalcs[gx.code_prefix_start].p, props.model.state.mx.baseP)"/>
              </td>
                    <td class="text-end">
                <t t-esc="fmt(props.model.state.mx.otherCalcs[gx.code_prefix_start].y)"/>
              </td>
                    <td class="text-end">
                <t t-esc="pct(props.model.state.mx.otherCalcs[gx.code_prefix_start].y, props.model.state.mx.baseY)"/>
              </td>
            </tr>
                <tr class="spacer-row"><td colspan="6"></td></tr>
          </t>
        </t>
      </tbody>
    </table>
  </t>

    <t t-name="kuale_income_statement.GroupRow" t-vars="group, pbase, ybase, level">
    <tr
            t-attf-class="#{(level &gt; 0 and group.group_id) ? ('child-row parent-g-' + group.group_id[0] + ' ') : ''}#{(((group.children ? group.children.length : 0) + (group.accounts ? group.accounts.length : 0)) &gt; 0) ? 'toggle ' : ''}level-#{level} fw-bold bg-light"
            t-attf-data-id="g-#{group.id}"
            t-on-click="onToggle">
    <td><t t-esc="group.code_prefix_start or ''"/></td>
        <td>
      <span t-attf-style="padding-left: #{level * 20}px">
        <t t-if="((group.children ? group.children.length : 0) + (group.accounts ? group.accounts.length : 0)) &gt; 0">
          <span class="k-toggle-icon">[+]</span>
        </t>
          <t t-esc="group.name"/>
      </span>
    </td>
        <td class="text-end"><t t-esc="fmt(group.period_total)"/></td>
        <td class="text-end"><t t-esc="pct(group.period_total, pbase)"/></td>
        <td class="text-end"><t t-esc="fmt(group.ytd_total)"/></td>
        <td class="text-end"><t t-esc="pct(group.ytd_total, ybase)"/></td>
  </tr>

        <!-- cuentas directas -->
        <t t-foreach="group.items" t-as="it" t-key="(it.kind == 'acc' and ('a-' + it.id)) or ('g-' + it.id)">
      <t t-if="it.kind == 'acc'">
        <tr class="child-row parent-g-#{group.id}" t-attf-data-id="a-#{it.id}">
          <td><t t-esc="it.ref.code"/></td>
            <td>
            <span t-attf-style="padding-left: #{(level + 1) * 20}px">
              <t t-esc="it.ref.name"/>
            </span>
          </td>
            <td class="text-end"><t t-esc="fmt(it.ref.period)"/></td>
            <td class="text-end"><t t-esc="pct(it.ref.period, group.period_total)"/></td>
            <td class="text-end"><t t-esc="fmt(it.ref.ytd)"/></td>
            <td class="text-end"><t t-esc="pct(it.ref.ytd, group.ytd_total)"/></td>
        </tr>
      </t>

            <!-- subgrupo -->
            <t t-if="it.kind == 'grp'">
        <t t-call="kuale_income_statement.GroupRow">
          <t t-set="group" t-value="it.ref"/>
            <t t-set="pbase" t-value="group.period_total"/>
            <t t-set="ybase" t-value="group.ytd_total"/>
            <t t-set="level" t-value="level + 1"/>
        </t>
      </t>
    </t>
  </t>

</templates>
