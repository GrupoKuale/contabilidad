<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    
    <t t-name="sat_cfdi.CFDIPreviewDialog" owl="1">
        <div class="modal-dialog modal-xl" style="max-width: 95%;">
            <div class="modal-content" style="height: 95vh;">
                <div class="modal-header bg-primary text-white py-2 d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center">
                        <i class="fa fa-file-pdf-o me-2 fa-lg"/>
                        <h5 class="modal-title mb-0">Vista Preliminar CFDI 4.0</h5>
                    </div>
                    
                    <div class="d-flex gap-2">
                         <button class="btn btn-light btn-sm text-primary fw-bold" t-on-click="generatePDF" t-att-disabled="state.loading">
                            <i class="fa fa-download me-1"/> Descargar PDF
                        </button>
                        
                        <button type="button" class="btn-close btn-close-white ms-2" t-on-click="close"/>
                    </div>
                </div>

                <div class="modal-body d-flex p-0" style="height: calc(95vh - 110px); overflow: hidden;">
                    
                    <t t-if="state.loading">
                        <div class="w-100 d-flex justify-content-center align-items-center bg-white">
                            <div class="text-center">
                                <i class="fa fa-circle-o-notch fa-spin fa-3x text-primary mb-3"/>
                                <p class="text-muted">Generando vista previa...</p>
                            </div>
                        </div>
                    </t>

                    <t t-else="">
                        <div class="border-end bg-light" style="width: 250px; min-width: 250px; overflow-y: auto; padding: 15px;">
                            <h6 class="text-primary fw-bold mb-3 border-bottom pb-2">
                                <i class="fa fa-eye me-2"/> Opciones de Vista
                            </h6>
                            <p class="small text-muted mb-3" style="font-size: 11px;">
                                Marca las casillas para mostrar u ocultar secciones en la representación impresa.
                            </p>

                            <div class="mb-3">
                                <div class="d-flex align-items-center mb-1">
                                    <input type="checkbox" class="form-check-input me-2" t-on-click="() => this.toggleSection('comprobante')"/>
                                    <label class="fw-bold small text-dark">Encabezado</label>
                                </div>
                                <div class="ms-3 border-start ps-2">
                                    <div class="form-check form-check-sm mb-0"><input type="checkbox" class="form-check-input" t-att-checked="state.visibleFields.version" t-on-click="() => this.toggleField('version')"/><label class="form-check-label small">Versión</label></div>
                                    <div class="form-check form-check-sm mb-0"><input type="checkbox" class="form-check-input" t-att-checked="state.visibleFields.serie" t-on-click="() => this.toggleField('serie')"/><label class="form-check-label small">Serie y Folio</label></div>
                                    <div class="form-check form-check-sm mb-0"><input type="checkbox" class="form-check-input" t-att-checked="state.visibleFields.fecha" t-on-click="() => this.toggleField('fecha')"/><label class="form-check-label small">Fecha</label></div>
                                    <div class="form-check form-check-sm mb-0"><input type="checkbox" class="form-check-input" t-att-checked="state.visibleFields.lugarExpedicion" t-on-click="() => this.toggleField('lugarExpedicion')"/><label class="form-check-label small">Lugar Exp.</label></div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex align-items-center mb-1">
                                    <input type="checkbox" class="form-check-input me-2" t-on-click="() => this.toggleSection('emisor')"/>
                                    <label class="fw-bold small text-dark">Participantes</label>
                                </div>
                                <div class="ms-3 border-start ps-2">
                                    <div class="form-check form-check-sm mb-0"><input type="checkbox" class="form-check-input" t-att-checked="state.visibleFields.emisorNombre" t-on-click="() => this.toggleField('emisorNombre')"/><label class="form-check-label small">Nombre Emisor</label></div>
                                    <div class="form-check form-check-sm mb-0"><input type="checkbox" class="form-check-input" t-att-checked="state.visibleFields.receptorNombre" t-on-click="() => this.toggleField('receptorNombre')"/><label class="form-check-label small">Nombre Receptor</label></div>
                                    <div class="form-check form-check-sm mb-0"><input type="checkbox" class="form-check-input" t-att-checked="state.visibleFields.receptorDomicilio" t-on-click="() => this.toggleField('receptorDomicilio')"/><label class="form-check-label small">Domicilio</label></div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex align-items-center mb-1">
                                    <input type="checkbox" class="form-check-input me-2" t-on-click="() => this.toggleSection('totales')"/>
                                    <label class="fw-bold small text-dark">Totales</label>
                                </div>
                                <div class="ms-3 border-start ps-2">
                                    <div class="form-check form-check-sm mb-0"><input type="checkbox" class="form-check-input" t-att-checked="state.visibleFields.subtotal" t-on-click="() => this.toggleField('subtotal')"/><label class="form-check-label small">Subtotal</label></div>
                                    <div class="form-check form-check-sm mb-0"><input type="checkbox" class="form-check-input" t-att-checked="state.visibleFields.impuestos" t-on-click="() => this.toggleField('impuestos')"/><label class="form-check-label small">Impuestos</label></div>
                                    <div class="form-check form-check-sm mb-0"><input type="checkbox" class="form-check-input" t-att-checked="state.visibleFields.total" t-on-click="() => this.toggleField('total')"/><label class="form-check-label small">Total</label></div>
                                </div>
                            </div>
                        </div>

                        <div class="flex-grow-1 bg-secondary bg-opacity-10 p-4" style="overflow-y: auto;">
                            
                            <div class="bg-white shadow-sm mx-auto p-5" style="max-width: 850px; min-height: 1000px; font-family: 'Liberation Sans', Arial, sans-serif; font-size: 11px; color: #333;">
                                
                                <div class="row mb-4">
                                    <div class="col-7">
                                        <div class="mb-2">
                                            <h2 class="fw-bold text-primary m-0" style="font-family: Arial Black, sans-serif;">DW IT Services</h2>
                                            <small class="text-muted fst-italic">Software empresarial</small>
                                        </div>
                                        
                                        <div class="mt-3">
                                            <div class="fw-bold mb-1" style="font-size: 13px;">Emisor:</div>
                                            <t t-if="state.visibleFields.emisorNombre">
                                                <div class="fw-bold text-uppercase"><t t-esc="state.invoiceData.emisor_nombre"/></div>
                                            </t>
                                            <t t-if="state.visibleFields.emisorRFC">
                                                <div>RFC: <span class="fw-bold"><t t-esc="state.invoiceData.emisor_rfc"/></span></div>
                                            </t>
                                            <t t-if="state.visibleFields.emisorRegimenFiscal">
                                                <div>Régimen Fiscal: 601 General de Ley Personas Morales</div>
                                            </t>
                                        </div>
                                    </div>

                                    <div class="col-5 text-end">
                                        <div class="mb-3">
                                            <div t-if="state.visibleFields.tipoComprobante">
                                                <span class="fw-bold">Tipo de Comprobante:</span> I - Ingreso
                                            </div>
                                            <div t-if="state.visibleFields.serie">
                                                <span class="fw-bold">Serie:</span> <t t-esc="state.invoiceData.serie || 'A'"/>
                                            </div>
                                            <div t-if="state.visibleFields.folio">
                                                <span class="fw-bold">Folio:</span> <t t-esc="state.invoiceData.folio || '001'"/>
                                            </div>
                                            <div t-if="state.visibleFields.fecha">
                                                <span class="fw-bold">Fecha:</span> <t t-esc="state.invoiceData.fecha"/>
                                            </div>
                                            <div t-if="state.visibleFields.lugarExpedicion" class="text-muted small mt-1">
                                                Lugar de expedición (C.P.): 44100
                                            </div>
                                        </div>

                                        <div class="small">
                                            <div t-if="state.visibleFields.metodoPago">
                                                <span class="fw-bold">Método de Pago:</span> <t t-esc="state.invoiceData.metodo_pago"/>
                                            </div>
                                            <div t-if="state.visibleFields.formaPago">
                                                <span class="fw-bold">Forma de Pago:</span> <t t-esc="state.invoiceData.forma_pago"/>
                                            </div>
                                            <div t-if="state.visibleFields.moneda">
                                                <span class="fw-bold">Moneda:</span> MXN - Peso Mexicano
                                            </div>
                                            <div t-if="state.visibleFields.tipoCambio">
                                                <span class="fw-bold">Tipo de Cambio:</span> 1.0000
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <hr class="border-secondary my-3 opacity-25"/>

                                <div class="mb-4">
                                    <div class="fw-bold mb-1" style="font-size: 13px;">Receptor:</div>
                                    <div class="row">
                                        <div class="col-12">
                                            <t t-if="state.visibleFields.receptorNombre">
                                                <div>Cliente: <span class="text-uppercase fw-bold"><t t-esc="state.invoiceData.receptor_nombre"/></span></div>
                                            </t>
                                            <t t-if="state.visibleFields.receptorRFC">
                                                <div>RFC: <t t-esc="state.invoiceData.receptor_rfc"/></div>
                                            </t>
                                            <t t-if="state.visibleFields.receptorUsoCFDI">
                                                <div>Uso CFDI: G03 - Gastos en general</div>
                                            </t>
                                            <t t-if="state.visibleFields.receptorDomicilio">
                                                <div>Domicilio Fiscal: 44100</div>
                                                <div>Régimen Fiscal: 616 Sin obligaciones fiscales</div>
                                            </t>
                                        </div>
                                    </div>
                                </div>

                                <t t-if="state.visibleFields.conceptos">
                                    <div class="mb-4">
                                        <table class="table table-sm table-bordered border-dark mb-0" style="font-size: 10px;">
                                            <thead style="background-color: #f2f2f2;">
                                                <tr class="text-center">
                                                    <th t-if="state.visibleFields.conceptoCantidad" style="width: 8%;">Cantidad</th>
                                                    <th t-if="state.visibleFields.conceptoUnidad" style="width: 10%;">Unidad</th>
                                                    <th t-if="state.visibleFields.conceptoClave" style="width: 10%;">Clave SAT</th>
                                                    <th t-if="state.visibleFields.conceptoDescripcion">Descripción</th>
                                                    <th t-if="state.visibleFields.conceptoValorUnitario" style="width: 12%;">Valor Unitario</th>
                                                    <th t-if="state.visibleFields.descuentos" style="width: 10%;">Descuento</th>
                                                    <th t-if="state.visibleFields.conceptoImpuestos" style="width: 12%;">Impuestos</th>
                                                    <th t-if="state.visibleFields.conceptoImporte" style="width: 12%;">Importe</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="state.invoiceData.conceptos" t-as="c" t-key="c.id">
                                                    <tr>
                                                        <td t-if="state.visibleFields.conceptoCantidad" class="text-center"><t t-esc="c.cantidad"/></td>
                                                        <td t-if="state.visibleFields.conceptoUnidad" class="text-center">H87</td>
                                                        <td t-if="state.visibleFields.conceptoClave" class="text-center"><t t-esc="c.clave"/></td>
                                                        <td t-if="state.visibleFields.conceptoDescripcion"><t t-esc="c.descripcion"/></td>
                                                        <td t-if="state.visibleFields.conceptoValorUnitario" class="text-end"><t t-esc="c.valor_unitario"/></td>
                                                        <td t-if="state.visibleFields.descuentos" class="text-end">$0.00</td>
                                                        <td t-if="state.visibleFields.conceptoImpuestos" class="text-end">IVA 0.16</td>
                                                        <td t-if="state.visibleFields.conceptoImporte" class="text-end"><t t-esc="c.importe"/></td>
                                                    </tr>
                                                </t>
                                                <tr t-if="state.invoiceData.conceptos.length &lt; 3" style="height: 25px;">
                                                    <td colspan="8" class="border-0"></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </t>

                                <div class="row">
                                    <div class="col-7">
                                        <div class="mb-3">
                                            <div class="fw-bold mb-1">Total con letra:</div>
                                            <div class="small text-muted text-uppercase">
                                                (IMPORTE CON LETRA NO DISPONIBLE EN VISTA PREVIA) PESOS 00/100 M.N.
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <div class="fw-bold small">CFDI Relacionados:</div>
                                            <div class="small text-muted">-</div>
                                        </div>
                                    </div>

                                    <div class="col-5">
                                        <table class="table table-sm table-borderless text-end mb-0" style="font-size: 11px;">
                                            <t t-if="state.visibleFields.subtotal">
                                                <tr>
                                                    <td class="fw-bold pe-2">Subtotal:</td>
                                                    <td width="40%"><t t-esc="state.invoiceData.subtotal"/></td>
                                                </tr>
                                            </t>
                                            <t t-if="state.visibleFields.descuentos">
                                                <tr>
                                                    <td class="fw-bold pe-2">Descuentos:</td>
                                                    <td>$0.00</td>
                                                </tr>
                                            </t>
                                            <t t-if="state.visibleFields.impuestos">
                                                <tr>
                                                    <td class="fw-bold pe-2">Impuestos Trasladados:</td>
                                                    <td><t t-esc="state.invoiceData.impuestos"/></td>
                                                </tr>
                                                <tr>
                                                    <td class="fw-bold pe-2">Impuestos Retenidos:</td>
                                                    <td>$0.00</td>
                                                </tr>
                                            </t>
                                            <t t-if="state.visibleFields.total">
                                                <tr class="border-top border-dark">
                                                    <td class="fw-bold pe-2 fs-6">Total:</td>
                                                    <td class="fw-bold fs-6"><t t-esc="state.invoiceData.total"/></td>
                                                </tr>
                                            </t>
                                        </table>
                                    </div>
                                </div>

                                <br/><br/>

                                <div class="row mt-4 align-items-end">
                                    <div class="col-3 text-center">
                                        <div style="width: 120px; height: 120px; background-color: #f8f9fa; border: 1px solid #ddd; display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                                            <i class="fa fa-qrcode fa-5x text-dark"/>
                                        </div>
                                    </div>
                                    
                                    <div class="col-9">
                                        <div class="mb-2 fw-bold text-center">Este documento es una representación impresa de un CFDI</div>
                                        
                                        <div class="small mb-1">
                                            <span class="fw-bold">Serie del Certificado del emisor:</span> 00001000000500000000
                                        </div>
                                        <div class="small mb-1">
                                            <span class="fw-bold">Folio Fiscal:</span> <t t-esc="state.invoiceData.uuid || '00000000-0000-0000-0000-000000000000'"/>
                                        </div>
                                        <div class="small mb-1">
                                            <span class="fw-bold">No. de serie del Certificado del SAT:</span> 00001000000509846663
                                        </div>
                                        <div class="small mb-1">
                                            <span class="fw-bold">Fecha y hora de certificación:</span> 2023-10-27T10:00:00
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-3 bg-light p-2 border border-secondary rounded-1" style="font-size: 8px; word-break: break-all;">
                                    <div class="fw-bold mb-1">Sello digital del CFDI</div>
                                    <div class="text-muted mb-2">
                                        gKx9L5... (Sello Digital de ejemplo para vista preliminar) ...
                                    </div>
                                    
                                    <div class="fw-bold mb-1">Sello del SAT</div>
                                    <div class="text-muted mb-2">
                                        XyZ123... (Sello SAT de ejemplo) ...
                                    </div>

                                    <div class="fw-bold mb-1">Cadena original del complemento de certificación digital del SAT</div>
                                    <div class="text-muted">
                                        ||1.1|00000000-0000-0000-0000-000000000000|2023-10-27T10:00:00|LSO1306189R5|...||
                                    </div>
                                </div>

                            </div>
                            </div>
                    </t>
                </div>

                <div class="modal-footer bg-light">
                    <button class="btn btn-secondary" t-on-click="close">
                        <i class="fa fa-times me-2"/>Cerrar
                    </button>
                    <button class="btn btn-primary" t-on-click="generatePDF">
                        <i class="fa fa-file-pdf-o me-2"/>Descargar PDF Oficial
                    </button>
                </div>
            </div>
        </div>
    </t>

</templates>