<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="contabilidad_kuale.ADDContpaqView" owl="1">
        <div class="add_contpaq_view d-flex flex-column h-100">
            
            <div class="add_toolbar p-2 border-bottom d-flex align-items-center gap-2 bg-white">
                
                <button class="btn btn-light border" t-on-click="toggleLeftPanel" 
                        t-att-title="state.showLeftPanel ? 'Ocultar Menú' : 'Mostrar Menú'">
                    <i t-att-class="state.showLeftPanel ? 'fa fa-chevron-left' : 'fa fa-chevron-right'"/>
                </button>

                <div class="btn-group">
                    <button class="btn btn-primary" t-on-click="onCargarXML" title="Cargar XML">
                        <i class="fa fa-plus"/> <span class="d-none d-lg-inline">Cargar</span>
                    </button>
                    <button class="btn btn-success" t-on-click="onAgregarADD" title="Agregar a ADD">
                        <i class="fa fa-folder-open"/> <span class="d-none d-lg-inline">ADD</span>
                    </button>
                    <button class="btn btn-info" t-on-click="onExportarXML" title="Exportar XML">
                        <i class="fa fa-download"/>
                    </button>
                </div>

                <div class="input-group" style="width: auto; min-width: 200px;">
                    <span class="input-group-text bg-light"><i class="fa fa-eye"/></span>
                    <select class="form-select" t-on-change="onApplyPreset" t-model="state.currentPresetId" style="max-width: 200px;">
                        <option value="">-- Vistas Guardadas --</option>
                        <t t-foreach="state.presets" t-as="preset" t-key="preset.id">
                            <option t-att-value="preset.id">
                                <t t-esc="preset.name"/>
                            </option>
                        </t>
                    </select>
                    <button class="btn btn-outline-secondary" t-on-click="onSavePreset" title="Guardar configuración actual">
                        <i class="fa fa-save"/>
                    </button>
                </div>

                <div class="flex-grow-1"/> <div class="btn-group">
                    <button class="btn btn-warning" t-on-click="onOpenFieldSelector" title="Seleccionar Columnas">
                        <i class="fa fa-columns"/> Campos
                    </button>
                    <button class="btn btn-success" t-on-click="onExportToExcel" title="Exportar a Excel">
                        <i class="fa fa-file-excel-o"/> Excel
                    </button>
                    <button class="btn btn-secondary" t-on-click="() => this.loadInvoices()" title="Actualizar">
                        <i class="fa fa-refresh"/>
                    </button>
                </div>

                <button class="btn btn-light border" t-on-click="toggleRightPanel"
                        t-att-title="state.showRightPanel ? 'Ocultar Opciones' : 'Mostrar Opciones'">
                    <i t-att-class="state.showRightPanel ? 'fa fa-chevron-right' : 'fa fa-chevron-left'"/>
                </button>
            </div>
            
            <div class="add_main_container d-flex flex-grow-1 overflow-hidden">
                
                <t t-if="state.showLeftPanel">
                    <div class="add_left_panel border-end overflow-auto bg-light" style="width: 260px; min-width: 260px; transition: all 0.3s;">
                        <div class="add_tree_view p-2">
                            
                            <div class="add_tree_section">
                                <div class="add_tree_item p-2 rounded" 
                                     t-on-click="onClickMiADD"
                                     t-att-class="state.activeFilters.addStatus === 'my_add' ? 'bg-primary text-white' : 'text-dark'"
                                     style="cursor: pointer;">
                                    <i class="fa fa-folder me-2"/> Mi ADD
                                </div>
                                <div class="add_tree_item p-2 rounded" 
                                     t-on-click="onClickDisponibles"
                                     t-att-class="state.activeFilters.addStatus === 'available' ? 'bg-primary text-white' : 'text-dark'"
                                     style="cursor: pointer;">
                                    <i class="fa fa-folder-open me-2"/> Documentos Disponibles
                                </div>
                            </div>
                            
                            <hr class="my-2"/>
                            
                            <div class="add_tree_section">
                                <div class="add_tree_parent p-2 rounded d-flex align-items-center" 
                                     t-on-click="onClickRecibidos"
                                     t-att-class="state.activeFilters.documentType === 'recibido' and !state.activeFilters.documentGroup ? 'bg-secondary text-white' : 'text-dark'"
                                     style="cursor: pointer;">
                                    <i t-att-class="state.xmlRecibidosExpanded ? 'fa fa-caret-down me-2' : 'fa fa-caret-right me-2'"/>
                                    <i class="fa fa-inbox me-2"/> XML Recibidos
                                </div>
                                
                                <t t-if="state.xmlRecibidosExpanded">
                                    <div class="ms-4">
                                        <div class="add_tree_child p-1 rounded" 
                                             t-on-click="() => this.onClickGroup('recibido', 'factura')"
                                             t-att-class="state.activeFilters.documentGroup === 'factura' ? 'fw-bold text-primary' : ''"
                                             style="cursor: pointer;">
                                            <i class="fa fa-file-text-o me-2"/> Facturas
                                        </div>
                                        <div class="add_tree_child p-1 rounded" 
                                             t-on-click="() => this.onClickGroup('recibido', 'pago')"
                                             t-att-class="state.activeFilters.documentGroup === 'pago' ? 'fw-bold text-primary' : ''"
                                             style="cursor: pointer;">
                                            <i class="fa fa-money me-2"/> Pagos
                                        </div>
                                        <div class="add_tree_child p-1 rounded" 
                                             t-on-click="() => this.onClickGroup('recibido', 'nomina')"
                                             t-att-class="state.activeFilters.documentGroup === 'nomina' ? 'fw-bold text-primary' : ''"
                                             style="cursor: pointer;">
                                            <i class="fa fa-users me-2"/> Nóminas
                                        </div>
                                        <div class="add_tree_child p-1 rounded" 
                                             t-on-click="() => this.onClickGroup('recibido', 'retencion')"
                                             t-att-class="state.activeFilters.documentGroup === 'retencion' ? 'fw-bold text-primary' : ''"
                                             style="cursor: pointer;">
                                            <i class="fa fa-file me-2"/> Retenciones
                                        </div>
                                    </div>
                                </t>
                            </div>
                            
                            <div class="add_tree_section mt-2">
                                <div class="add_tree_parent p-2 rounded d-flex align-items-center" 
                                     t-on-click="onClickEmitidos"
                                     t-att-class="state.activeFilters.documentType === 'emitido' and !state.activeFilters.documentGroup ? 'bg-secondary text-white' : 'text-dark'"
                                     style="cursor: pointer;">
                                    <i t-att-class="state.xmlEmitidosExpanded ? 'fa fa-caret-down me-2' : 'fa fa-caret-right me-2'"/>
                                    <i class="fa fa-send me-2"/> XML Emitidos
                                </div>
                                
                                <t t-if="state.xmlEmitidosExpanded">
                                    <div class="ms-4">
                                        <div class="add_tree_child p-1 rounded" 
                                             t-on-click="() => this.onClickGroup('emitido', 'factura')"
                                             t-att-class="state.activeFilters.documentGroup === 'factura' ? 'fw-bold text-primary' : ''"
                                             style="cursor: pointer;">
                                            <i class="fa fa-file-text-o me-2"/> Facturas
                                        </div>
                                        <div class="add_tree_child p-1 rounded" 
                                             t-on-click="() => this.onClickGroup('emitido', 'pago')"
                                             t-att-class="state.activeFilters.documentGroup === 'pago' ? 'fw-bold text-primary' : ''"
                                             style="cursor: pointer;">
                                            <i class="fa fa-money me-2"/> Pagos
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </t>
                
                <div class="add_center_panel flex-grow-1 overflow-auto bg-white">
                    <table class="add_table table table-hover table-striped mb-0">
                        <thead class="sticky-top bg-white shadow-sm">
                            <tr>
                                <th class="add_checkbox_col" style="width: 40px;">
                                    <input type="checkbox" 
                                           class="form-check-input"
                                           t-on-change="(ev) => this.onSelectAll(ev.target.checked)"/>
                                </th>
                                
                                <t t-foreach="state.visibleFields" t-as="fieldName" t-key="fieldName">
                                    <th><t t-esc="getFieldLabel(fieldName)"/></th>
                                </t>
                                
                                <th class="add_actions_col text-end" style="min-width: 120px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="state.invoices.length === 0">
                                <tr>
                                    <td t-att-colspan="state.visibleFields.length + 2" class="text-center text-muted p-5">
                                        <i class="fa fa-inbox fa-3x mb-3 text-secondary"/>
                                        <p class="h5">No hay documentos que mostrar</p>
                                    </td>
                                </tr>
                            </t>
                            
                            <t t-foreach="state.invoices" t-as="invoice" t-key="invoice.id">
                                <tr t-att-class="state.selectedInvoices.includes(invoice.id) ? 'table-info' : ''">
                                    <td>
                                        <input type="checkbox" 
                                               class="form-check-input"
                                               t-att-checked="state.selectedInvoices.includes(invoice.id)"
                                               t-on-change="(ev) => this.onSelectInvoice(invoice.id, ev.target.checked)"/>
                                    </td>
                                    
                                    <t t-foreach="state.visibleFields" t-as="fieldName" t-key="fieldName">
                                        <td class="align-middle"><t t-esc="getFieldValue(invoice, fieldName)"/></td>
                                    </t>
                                    
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-link text-info" 
                                                t-on-click="() => this.onOpenPreview(invoice.id)"
                                                title="Vista Preliminar">
                                            <i class="fa fa-eye"/>
                                        </button>
                                        
                                        <button class="btn btn-sm btn-link text-secondary" 
                                                t-on-click="() => this.onVerXML(invoice.id)"
                                                title="Ver XML">
                                            <i class="fa fa-file-code-o"/>
                                        </button>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
                
                <t t-if="state.showRightPanel">
                    <div class="add_right_panel border-start bg-light p-3 overflow-auto" style="width: 250px; min-width: 250px;">
                        
                        <div class="mb-4">
                            <h6 class="fw-bold mb-2 text-primary"><i class="fa fa-calendar"/> Periodo</h6>
                            <div class="mb-2">
                                <label class="small text-muted">Desde:</label>
                                <input type="date" class="form-control form-control-sm" 
                                       t-model="state.dateFrom" t-on-change="onDateChange"/>
                            </div>
                            <div>
                                <label class="small text-muted">Hasta:</label>
                                <input type="date" class="form-control form-control-sm" 
                                       t-model="state.dateTo" t-on-change="onDateChange"/>
                            </div>
                        </div>

                        <hr/>

                        <div class="add_right_section">
                            <h6 class="fw-bold mb-3 text-primary">
                                <i class="fa fa-cog"/> Visualización
                            </h6>
                            
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="chk_add" t-model="state.rightPanelChecks.add"/>
                                <label class="form-check-label" for="chk_add">Estado ADD</label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="chk_rel" t-model="state.rightPanelChecks.cfdiRelacionado"/>
                                <label class="form-check-label" for="chk_rel">CFDI Relacionado</label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="chk_comp" t-model="state.rightPanelChecks.comprobante"/>
                                <label class="form-check-label" for="chk_comp">Datos Comprobante</label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="chk_conc" t-model="state.rightPanelChecks.conceptoFactura"/>
                                <label class="form-check-label" for="chk_conc">Conceptos</label>
                            </div>
                        </div>
                    </div>
                </t>
            </div>
            
            <div class="add_statusbar bg-white border-top p-2 d-flex justify-content-between small text-muted">
                <div>
                    <i class="fa fa-list"/> Total: <strong><t t-esc="state.invoices.length"/></strong>
                </div>
                <div>
                    <i class="fa fa-check-square-o"/> Seleccionados: <strong><t t-esc="state.stats.documentosSeleccionados"/></strong>
                </div>
                <div>
                    <i class="fa fa-dollar"/> Importe Sel: <strong>$<t t-esc="state.stats.importeTotalSeleccionado.toFixed(2)"/></strong>
                </div>
                <div>
                    <i class="fa fa-columns"/> Campos: <strong><t t-esc="state.visibleFields.length"/></strong>
                </div>
            </div>
        </div>
    </t>
    
    <t t-name="contabilidad_kuale.FieldSelectorDialog" owl="1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fa fa-columns"/> Seleccionar Campos Visibles
                    </h5>
                    <button type="button" class="btn-close" t-on-click="onCancel"/>
                </div>
                
                <div class="modal-body">
                    <t t-if="state.loading">
                        <div class="text-center p-5">
                            <i class="fa fa-spinner fa-spin fa-3x text-primary"/>
                            <p class="mt-3">Cargando campos disponibles...</p>
                        </div>
                    </t>
                    
                    <t t-else="">
                        <p class="text-muted small mb-3">Marque los campos que desea visualizar en la tabla principal:</p>
                        
                        <div class="row">
                            <t t-foreach="state.availableFields" t-as="field" t-key="field.name">
                                <div class="col-md-6 mb-2">
                                    <label class="d-flex align-items-center p-2 border rounded hover-bg-light" style="cursor: pointer;">
                                        <input type="checkbox" 
                                               class="form-check-input me-2"
                                               t-att-checked="isSelected(field.name)"
                                               t-on-change="() => this.toggleField(field.name)"/>
                                        <span class="small"><t t-esc="field.label"/></span>
                                    </label>
                                </div>
                            </t>
                        </div>
                        
                        <t t-if="state.availableFields.length === 0">
                            <div class="alert alert-warning">
                                <i class="fa fa-exclamation-triangle"/> No se encontraron campos disponibles
                            </div>
                        </t>
                    </t>
                </div>
                
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" t-on-click="onCancel">
                        <i class="fa fa-times"/> Cancelar
                    </button>
                    <button type="button" class="btn btn-primary" t-on-click="onConfirm" t-att-disabled="state.loading">
                        <i class="fa fa-check"/> Aplicar Cambios
                    </button>
                </div>
            </div>
        </div>
    </t>

</templates>