<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
  <t t-name="kuale_static_balance.Renderer">
      <style>
            .acc-row { background-color: #E2EAF4; }
            .fw-bold-parent {font-weight: bold; !important}
        </style>
      <!-- Header -->
      <header>
      <div class="ms-auto d-flex gap-2">
        <button class="btn btn-sm btn-primary" t-on-click="exportToExcel">
          <i class="fa fa-file-excel-o me-1"/>
            Exportar a Excel
        </button>
        <button class="btn btn-sm btn-secondary" t-on-click="exportToPDF">
          <i class="fa fa-file-pdf-o me-1"/>
            Guardar PDF
        </button>
      </div>
    </header>

      <!-- Filtros -->
      <div class="mb-3 d-flex align-items-center gap-3">
      <div>
        <label for="company-select" class="form-label mb-1">Compañía:</label>
          <select id="company-select" class="form-select form-select-sm w-auto d-inline-block"
                  t-model="state.selectedCompanyId" t-on-change="onCompanyChange">
          <t t-foreach="state.companyList" t-as="company" t-key="company.id">
            <option t-att-value="company.id" t-esc="company.name"/>
          </t>
        </select>
      </div>

      <div>
        <label for="branch-select" class="form-label mb-1">Sucursal:</label>
          <select id="branch-select" class="form-select form-select-sm w-auto d-inline-block"
                  t-model="state.selectedBranchId" t-on-change="onBranchChange">
          <t t-foreach="state.branchList" t-as="branch" t-key="branch.id or 'all'">
            <option t-att-value="branch.id" t-esc="branch.name"/>
          </t>
        </select>
      </div>

          <div>
        <label for="sat-nivel-select" class="form-label mb-1">Nivel SAT:</label>
              <select id="sat-nivel-select" class="form-select form-select-sm w-auto d-inline-block"
                      t-model="state.selectedSatNivel" t-on-change="onSatNivelChange">
          <t t-foreach="state.satNivelList" t-as="opt" t-key="opt.value or 'all'">
            <option t-att-value="opt.value" t-esc="opt.label"/>
          </t>
        </select>
      </div>

          <div class="form-check mt-4">
        <input class="form-check-input" type="checkbox" id="include-empty"
               t-att-checked="state.includeEmpty ? 'checked' : null"
               t-on-change="onIncludeEmptyToggle"/>
              <label class="form-check-label" for="include-empty">Incluir grupos/cuentas sin movimientos</label>
      </div>

          <!-- Rango de fechas -->
          <div class="d-flex gap-3">
        <div>
          <label for="from-date" class="form-label mb-1">Desde:</label>
            <input type="date" id="from-date" class="form-control form-control-sm"
                   t-model="state.fromDate" t-on-change="onDateChange"/>
        </div>
              <div>
          <label for="to-date" class="form-label mb-1">Hasta:</label>
                  <input type="date" id="to-date" class="form-control form-control-sm"
                         t-model="state.toDate" t-on-change="onDateChange"/>
        </div>
      </div>
    </div>

      <!-- Tabla -->
      <table class="table table-sm table-hover table-striped" style="margin-bottom: 50px !important;">
      <thead>
        <tr>
          <th>Nombre</th>
            <th>Código</th>
            <th class="text-end">Saldo Inicial</th>
            <th class="text-end">Débito</th>
            <th class="text-end">Crédito</th>
            <th class="text-end">Saldo Final</th>
        </tr>
      </thead>

          <tbody>
        <!-- Pintamos todo “plano”: grupos raíz, sus cuentas y subgrupos,
             pero sin indentación ni toggles -->
              <t t-foreach="props.model.state.groups or []" t-as="group" t-key="group.id">
          <t t-call="kuale_static_balance.GroupRowFlat">
            <t t-set="group" t-value="group"/>
          </t>
        </t>
      </tbody>
    </table>
  </t>

    <!-- Una fila por grupo + render recursivo de sus hijos SIN indentación ni toggle -->
    <t t-name="kuale_static_balance.GroupRowFlat" t-vars="group">
    <!-- Grupo: negritas solo si NO tiene padre (grupo raíz) -->
        <tr t-attf-class="#{group.group_id ? '' : 'fw-bold-parent'}">
      <td><t t-esc="group.name"/></td>
            <td><t t-esc="group.code_prefix_start or ''"/></td>
            <td class="text-end"><t t-esc="(group.initial_balance_total or 0).toFixed(2)"/></td>
            <td class="text-end"><t t-esc="(group.debit_total or 0).toFixed(2)"/></td>
            <td class="text-end"><t t-esc="(group.credit_total or 0).toFixed(2)"/></td>
            <td class="text-end"><t t-esc="(group.ending_balance_total or 0).toFixed(2)"/></td>
    </tr>

        <!-- Cuentas directas del grupo (planas) -->
        <t t-foreach="group.items" t-as="it" t-key="(it.kind == 'acc' and ('a-' + it.id)) or ('g-' + it.id)">
      <t t-if="it.kind == 'acc'">
        <tr class="acc-row">
          <td><t t-esc="it.ref.name"/></td>
            <td><t t-esc="it.ref.code"/></td>
            <td class="text-end"><t t-esc="(it.ref.initial_balance or 0).toFixed(2)"/></td>
            <td class="text-end"><t t-esc="(it.ref.debit or 0).toFixed(2)"/></td>
            <td class="text-end"><t t-esc="(it.ref.credit or 0).toFixed(2)"/></td>
            <td class="text-end"><t t-esc="(it.ref.ending_balance or 0).toFixed(2)"/></td>
        </tr>
      </t>
    </t>

        <!-- Subgrupos (también planos; SIN negritas si tienen padre) -->
        <t t-foreach="group.items" t-as="it2" t-key="'sub-'+((it2.kind == 'grp' and it2.id) or ('acc-'+it2.id))">
      <t t-if="it2.kind == 'grp'">
        <t t-call="kuale_static_balance.GroupRowFlat">
          <t t-set="group" t-value="it2.ref"/>
        </t>
      </t>
    </t>
  </t>
</templates>
