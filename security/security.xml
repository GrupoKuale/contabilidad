<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record model="res.groups" id="group_account_dashboard">
            <field name="name">Access to Accounting Dashboard</field>
        </record>
        <record id="account_asset_category_multi_company_rule" model="ir.rule">
            <field name="name">Account Asset Category multi-company</field>
            <field ref="model_account_asset_category" name="model_id"/>
            <field eval="True" name="global"/>
            <field name="domain_force">
                ['|',('company_id','=',False),('company_id','child_of',[user.company_id.id])]
            </field>
        </record>
        <record id="account_asset_asset_multi_company_rule" model="ir.rule">
            <field name="name">Account Asset multi-company</field>
            <field ref="model_account_asset_asset" name="model_id"/>
            <field eval="True" name="global"/>
            <field name="domain_force">
                ['|',('company_id','=',False),('company_id','child_of',[user.company_id.id])]
            </field>
        </record>
        <!--    Rename user group as Accountant    -->
        <record id="account.group_account_user" model="res.groups">
            <field name="name">Accountant</field>
            <field name="implied_ids"
                   eval="[(4, ref('account.group_account_invoice'))]"/>
            <field name="category_id"
                   ref="base.module_category_accounting_accounting"/>
        </record>
        <!--    Rename user group as Chief Accountant    -->
        <record id="account.group_account_manager" model="res.groups">
            <field name="name">Chief Accountant</field>
            <field name="implied_ids"
                   eval="[(3, ref('account.group_account_invoice')), (4, ref('account.group_account_user'))]"/>
            <field name="category_id"
                   ref="base.module_category_accounting_accounting"/>
        </record>

        <record id="group_stock_picking_superuser_validate" model="res.groups">
            <field name="name">Confirmar movimientos de inventario </field>
            <field name="category_id" ref="base.module_category_inventory"/>
        </record>

        <!-- product company group -->
        <record id="product_template_company_group_rule" model="ir.rule">
            <field name="name">Product company group</field>
            <field name="model_id" ref="model_product_template"/>
            <field name="domain_force">["|",  "|",("company_group", "=", user.company_group), (user.see_all_company_groups, "=", True),("company_group", "=", False)]</field>
        </record>

        <record id="product_category_company_group_rule" model="ir.rule">
            <field name="name">Product Category - Company Group</field>
            <field name="model_id" ref="product.model_product_category"/>
            <field name="domain_force">["|", "|", ("company_group", "=", user.company_group), (user.see_all_company_groups, "=", True),("company_group", "=", False)]</field>
        </record>

        <record id="product_packaging_company_group_rule" model="ir.rule">
            <field name="name">Product Packaging - Company Group</field>
            <field name="model_id" ref="product.model_product_packaging"/>
            <field name="domain_force">["|",  "|", ("company_group", "=", user.company_group), (user.see_all_company_groups, "=", True),("company_group", "=", False)]</field>
        </record>

<!--   filter tickets by company     -->
        <record id="ticket_monitor_rule_company" model="ir.rule">
            <field name="name">Ticket Monitor - Company Filter</field>
            <field name="model_id" ref="model_contabilidad_kuale_ticket_monitor"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

<!--   Vistas campos ADD     -->
        <record id="rule_sat_add_view_preset_personal" model="ir.rule">
            <field name="name">Mis Presets de Vista ADD</field>
            <field name="model_id" ref="model_sat_add_view_preset"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

    </data>
</odoo>
