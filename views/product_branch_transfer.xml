<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_interbranch_transfer_tree" model="ir.ui.view">
            <field name="name">interbranch.transfer.tree</field>
            <field name="model">contabilidad_kuale.product_transfer</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="date"/>
                    <field name="company_id"/>
                    <field name="origin_branch_id"/>
                    <field name="dest_branch_id"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_interbranch_transfer_form" model="ir.ui.view">
            <field name="name">interbranch.transfer.form</field>
            <field name="model">contabilidad_kuale.product_transfer</field>
            <field name="arch" type="xml">
                <form string="Traspaso entre Sucursales">
                    <header>
                        <button name="action_transfer" type="object" string="Transferir"
                                class="btn-primary" invisible="state in 'transferred'"/>
                        <button name="action_receive" type="object" string="Marcar como Recibido"
                                class="btn-success" invisible="state not in 'transferred'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,transferred,received,cancel"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="date"/>
                                <field name="origin_branch_id"/>
                            </group>
                            <group>
                                <field name="company_id"/>
                                <field name="dest_branch_id"/>
                            </group>
                        </group>
                        <group readonly="1" invisible="state in 'draft'">
                            <separator string="Informacion sobre el traspaso"/>
                            <group>
                                <field name="picking_out_id" readonly="1"
                                       invisible="state not in ('transferred','received')"/>
                            </group>
                            <group>
                                <field name="picking_in_id" readonly="1" invisible="state not in 'received'"/>
                            </group>
                        </group>

                        <separator string="Productos a Transferir"/>
                        <field name="line_ids">
                            <tree editable="bottom">
                                <field name="product_id"/>
                                <field name="capture_mode"/>

                                <field name="unit_qty" invisible="capture_mode not in 'unit'"/>
                                <field name="packaging_id" invisible="capture_mode not in 'package'"/>
                                <field name="package_qty" invisible="capture_mode not in 'package'"/>

                                <field name="quantity" readonly="1"/>
                                <field name="uom" readonly="1"/>
                                <field name="stock_available" readonly="1"/>
                                <field name="stock_after_transfer" readonly="1"/>
                            </tree>
                        </field>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_interbranch_transfer_search" model="ir.ui.view">
            <field name="name">interbranch.transfer.search</field>
            <field name="model">contabilidad_kuale.product_transfer</field>
            <field name="arch" type="xml">
                <search>
                    <field name="date"/>
                    <field name="origin_branch_id"/>
                    <field name="dest_branch_id"/>
                    <field name="state"/>
                </search>
            </field>
        </record>

        <record id="action_interbranch_transfer" model="ir.actions.act_window">
            <field name="name">Traspasos entre Sucursales</field>
            <field name="res_model">contabilidad_kuale.product_transfer</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_interbranch_transfer" name="Traspasos entre Sucursales"
                  parent="stock.menu_stock_inventory_control" action="action_interbranch_transfer"/>

    </data>
</odoo>