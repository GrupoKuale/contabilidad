<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- product category -->
    <record id="product_category_form_view_company_group" model="ir.ui.view">
        <field name="name">product.category.form.inherit.company.group</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="after">
                <field name="is_shared_category" 
                       widget="boolean_toggle"
                       string="Categoría Compartida"
                       groups="base.group_system"/>
                <field name="expense_ok"/>
                <field name="company_group"/>
            </xpath>
        </field>
    </record>

    <record id="product_category_tree_view_company_group" model="ir.ui.view">
        <field name="name">product.category.tree.inherit.company.group</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_list_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='display_name']" position="after">
                <field name="is_shared_category" 
                       string="Compartida" 
                       optional="hide"
                       groups="base.group_system"/>
                <field name="company_group"/>
            </xpath>
        </field>
    </record>

    <!-- product packaging -->
    <record id="product_packaging_form_view_inherit_company_group" model="ir.ui.view">
        <field name="name">product.packaging.form.view.inherit.company.group</field>
        <field name="model">product.packaging</field>
        <field name="inherit_id" ref="product.product_packaging_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='qty']//field[@name='company_id']" position="before">
                <field name="company_group" required="1"/>
            </xpath>
        </field>
    </record>

    <record id="product_packaging_tree_view_inherit_company_group" model="ir.ui.view">
        <field name="name">product.packaging.tree.view.inherit.company.group</field>
        <field name="model">product.packaging</field>
        <field name="inherit_id" ref="product.product_packaging_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_uom_id']" position="after">
                <field name="company_group" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="product_packaging_tree_view2_inherit_partner" model="ir.ui.view">
        <field name="name">product.packaging.tree.inherit.partner</field>
        <field name="model">product.packaging</field>
        <field name="inherit_id" ref="product.product_packaging_tree_view2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='package_type_id']" position="after">
                <field name="partner_id" string="Proveedor" optional="show"/>
            </xpath>
        </field>
    </record>
    <!-- product tag -->
    <record id="product_tag_form_view_inherit_product_category" model="ir.ui.view">
        <field name="name">product.tag.view.form.product.category</field>
        <field name="model">product.tag</field>
        <field name="inherit_id" ref="product.product_tag_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="category_id"/>
            </xpath>
        </field>
    </record>
</odoo>