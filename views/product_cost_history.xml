<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_product_cost_history_tree" model="ir.ui.view">
            <field name="name">product.cost.history.tree</field>
            <field name="model">product.cost.history</field>
            <field name="arch" type="xml">
                <tree default_order="date desc">
                    <field name="company_id"/>
                    <field name="branch_id"/>
                    <field name="product_id"/>
                    <field name="recipe_cost"/>
                    <field name="date"/>
                </tree>
            </field>
        </record>
        <record id="view_product_cost_history_form" model="ir.ui.view">
            <field name="name">product.cost.history.form</field>
            <field name="model">product.cost.history</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="date"/>
                            <field name="company_id"/>
                            <field name="branch_id"/>
                            <field name="product_id"/>
                            <field name="recipe_cost"/>
                        </group>
                        <notebook>
                            <page string="Detalles de Ingredientes">
                                <field name="cost_line_ids">
                                    <tree editable="bottom">
                                        <field name="component_id"/>
                                        <field name="quantity"/>
                                        <field name="unit_price"/>
                                        <field name="total_price"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_product_cost_history_search" model="ir.ui.view">
            <field name="name">product.cost.history.search</field>
            <field name="model">product.cost.history</field>
            <field name="arch" type="xml">
                <search>
                    <field name="date"/>
                    <field name="product_id"/>
                    <field name="company_id"/>
                    <field name="branch_id"/>
                </search>
            </field>
        </record>
        <record id="action_product_cost_history" model="ir.actions.act_window">
            <field name="name">Historial de Costos</field>
            <field name="res_model">product.cost.history</field>
            <field name="view_mode">tree,form</field>
        </record>


        <menuitem id="menu_product_cost_history" name="Historial de Costos por Producto"
          parent="stock.menu_stock_inventory_control" action="action_product_cost_history"/>


    </data>
</odoo>