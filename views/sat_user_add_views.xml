<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sat_user_add_form_view" model="ir.ui.view">
        <field name="name">sat.user.add.form</field>
        <field name="model">sat.user.add</field>
        <field name="arch" type="xml">
            <form string="Mi ADD - Administrador de Documentos Digitales">
                <header>
                    <button name="action_refresh_statistics" 
                            string="Actualizar Estadísticas" 
                            type="object" 
                            class="btn-secondary"/>
                    <button name="action_view_documents" 
                            string="Ver Todos los Documentos" 
                            type="object" 
                            class="oe_highlight"/>
                </header>
                
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_documents" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-folder-open">
                            <field name="total_documents" widget="statinfo" string="Documentos"/>
                        </button>
                        
                        <button name="action_view_documents" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-lock"
                                context="{'search_default_locked': 1}">
                            <field name="total_locked" widget="statinfo" string="En Proceso"/>
                        </button>
                        
                        <button name="action_view_documents" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-check-circle"
                                context="{'search_default_processed': 1}">
                            <field name="total_processed" widget="statinfo" string="Procesados"/>
                        </button>
                    </div>
                    
                    <widget name="web_ribbon" text="Activo" bg_color="bg-success" 
                            invisible="not active"/>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                        <h3>
                            <field name="user_id" readonly="1" options="{'no_create': True}"/>
                        </h3>
                    </div>
                    
                    <!-- Estadísticas Generales -->
                    <group>
                        <group string="Estadísticas Generales">
                            <field name="total_documents" readonly="1"/>
                            <field name="total_amount" widget="monetary" readonly="1"/>
                            <field name="last_update" readonly="1"/>
                            <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                        </group>
                        
                        <group string="Por Tipo de Documento">
                            <field name="total_recibidos" readonly="1"/>
                            <field name="total_emitidos" readonly="1"/>
                        </group>
                    </group>
                    
                    <group>
                        <group string="Por Grupo">
                            <field name="total_facturas" readonly="1"/>
                            <field name="total_pagos" readonly="1"/>
                            <field name="total_nominas" readonly="1"/>
                        </group>
                        
                        <group string="Por Estado">
                            <field name="total_locked" readonly="1"/>
                            <field name="total_processed" readonly="1"/>
                        </group>
                    </group>
                    
                    <group>
                        <group string="Configuración">
                            <field name="auto_process"/>
                            <field name="active"/>
                            <field name="date_created" readonly="1"/>
                        </group>
                        
                        <group string="Notas">
                            <field name="notes" nolabel="1" placeholder="Agregue notas personales sobre su ADD..."/>
                        </group>
                    </group>
                    
                    <!-- Lista de Documentos -->
                    <notebook>
                        <page string="Documentos en ADD">
                            <field name="invoice_ids" mode="tree">
                                <tree decoration-success="add_status == 'processed'"
                                      decoration-warning="add_status == 'locked'">
                                    <field name="tfd_uuid"/>
                                    <field name="factura_fecha"/>
                                    <field name="document_type" widget="badge"/>
                                    <field name="document_group"/>
                                    <field name="nombre_emisor"/>
                                    <field name="factura_total" sum="Total"/>
                                    <field name="add_status" widget="badge"/>
                                    <field name="sat_status" widget="badge"/>
                                    <field name="add_date"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ========== Tree ========== -->
    <record id="sat_user_add_tree_view" model="ir.ui.view">
        <field name="name">sat.user.add.tree</field>
        <field name="model">sat.user.add</field>
        <field name="arch" type="xml">
            <tree string="ADDs de Usuarios">
                <field name="user_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="total_documents"/>
                <field name="total_recibidos"/>
                <field name="total_emitidos"/>
                <field name="total_amount" sum="Total"/>
                <field name="total_locked"/>
                <field name="total_processed"/>
                <field name="last_update"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- ========= Search ========== -->
    <record id="sat_user_add_search_view" model="ir.ui.view">
        <field name="name">sat.user.add.search</field>
        <field name="model">sat.user.add</field>
        <field name="arch" type="xml">
            <search string="Buscar ADDs">
                <field name="user_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                
                <filter string="Mi ADD" name="my_add" 
                        domain="[('user_id', '=', uid)]"/>
                <filter string="Activos" name="active" 
                        domain="[('active', '=', True)]"/>
                <filter string="Inactivos" name="inactive" 
                        domain="[('active', '=', False)]"/>
                
                <group expand="0" string="Agrupar por">
                    <filter string="Usuario" name="group_user" 
                            context="{'group_by': 'user_id'}"/>
                    <filter string="Compañía" name="group_company" 
                            context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sat_my_user_add" model="ir.actions.act_window">
        <field name="name">Mi ADD</field>
        <field name="res_model">sat.user.add</field>
        <field name="view_mode">form</field>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="context">{'search_default_my_add': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Bienvenido a su ADD
            </p>
            <p>
                Su Administrador de Documentos Digitales será creado automáticamente.
            </p>
        </field>
    </record>

    <record id="action_sat_all_user_adds" model="ir.actions.act_window">
        <field name="name">ADDs de Usuarios</field>
        <field name="res_model">sat.user.add</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay ADDs creados
            </p>
        </field>
    </record>

    <menuitem id="menu_sat_my_user_add" 
              name="Dashboard de mi ADD" 
              parent="menu_sat_add_section" 
              action="action_sat_my_user_add" 
              sequence="0"/>

    <menuitem id="menu_sat_all_adds" 
              name="Gestión de ADDs" 
              parent="menu_sat_tools" 
              action="action_sat_all_user_adds" 
              sequence="10"
              groups="base.group_system"/>

</odoo>
