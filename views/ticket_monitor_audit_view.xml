<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_ticket_monitor_audit_form" model="ir.ui.view">
            <field name="name">ticket.monitor.audit.form</field>
            <field name="model">contabilidad_kuale.ticket_monitor_audit</field>
            <field name="arch" type="xml">
                <form string="Formulario de Auditoría de Tickets">
                    <field name="child_company_ids" invisible="1"/>
                    <group>
                        <separator string="General"/>
                        <group>
                            <field name="company_id"/>
                            <field name="branch_id"/>
                            <field name="ticket_folio"/>
                            <field name="date"/>
                            <field name="sell_type_code" invisible="1"/>
                            <field name="cashier" invisible="sell_type_code == '1004'"/>
                            <field name="eoi_text" string="Cajero inicial" invisible="sell_type_code != '1004'"/>
                            <field name="closing_cashier" invisible="sell_type_code == '1004'"/>
                            <field name="eoi_text" string="Cajero final" invisible="sell_type_code != '1004'"/>
                        </group>
                        <group>
                            <field name="difference"/>
                            <field name="audit_status"/>
                            <field name="audit_ticket_status"/>
                            <field name="closed_date"/>
                            <field name="closing_time"/>
                            <field name="motive"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <separator string="Ticket en sistema"/>
                            <field name="ticket_payment_method" readonly="1"/>
                            <field name="ticket_payment_type" readonly="1"/>
                            <field name="ticket_iva" readonly="1"/>
                            <field name="ticket_total" readonly="1"/>
                            <field name="ticket_subtotal" readonly="1"/>
                            <field name="ticket_discount_ids" widget="many2many_tags" readonly="1"/>
                            <field name="ticket_discount" readonly="1"/>
                            <field name="ticket_discount_authorized" readonly="1"/>
                            <field name="ticket_void_authorized" readonly="1"/>
                            <field name="ticket_reprint_number" readonly="1"/>

                            <separator string="Linea de venta"/>
                            <field name="ticket_product_line">
                                <tree editable="bottom">
                                    <field name="third_party_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="discount"/>
                                    <field name="subtotal"/>
                                </tree>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="third_party_id"/>
                                            <field name="quantity"/>
                                            <field name="unit_price"/>
                                            <field name="discount"/>
                                            <field name="subtotal"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                            <separator string="Desglose de pago"/>
                            <field name="ticket_payments_ids">
                                <tree editable="False">
                                    <field name="payment_type"/>
                                    <field name="amount"/>
                                </tree>
                            </field>



                        </group>
                        <group>
                            <separator string="Ticket en auditoria"/>
                            <field name="audit_payment_method" readonly="1"/>
                            <field name="audit_payment_type" readonly="1"/>
                            <field name="audit_iva" readonly="1"/>
                            <field name="audit_total" readonly="1"/>
                            <field name="audit_subtotal" readonly="1"/>
                            <field name="audit_discount_ids" widget="many2many_tags" readonly="1"/>
                            <field name="audit_discount" readonly="1"/>
                            <field name="audit_discount_authorized" readonly="1"/>
                            <field name="audit_void_authorized" readonly="1"/>
                            <field name="audit_reprint_number" readonly="1"/>

                            <separator string="Linea de venta"/>
                            <field name="audit_product_line">
                                <tree editable="bottom">
                                    <field name="third_party_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="discount"/>
                                    <field name="subtotal"/>
                                </tree>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="third_party_id"/>
                                            <field name="quantity"/>
                                            <field name="unit_price"/>
                                            <field name="discount"/>
                                            <field name="subtotal"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                            <separator string="Desglose de pago"/>
                            <field name="audit_payments_ids">
                                <tree editable="false">
                                    <field name="payment_type"/>
                                    <field name="amount"/>
                                </tree>
                            </field>

                        </group>

                    </group>

                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_ticket_monitor_audit_tree" model="ir.ui.view">
            <field name="name">ticket.monitor.audit.tree</field>
            <field name="model">contabilidad_kuale.ticket_monitor_audit</field>
            <field name="arch" type="xml">
                <tree string="Monitoreo de Auditoria de Tickets" js_class="adaptative_filter">
                    <field name="company_id"/>
                    <field name="branch_id"/>
                    <field name="ticket_folio"/>
                    <field name="date"/>
                    <field name="ticket_total" string="Total del ticket"/>
                    <field name="audit_total" string="Total de auditoria"/>
                    <field name="difference"/>
                    <field name="audit_status" widget="badge" decoration-success="audit_status == 'sistema'"
                           decoration-danger="audit_status == 'auditoria'" decoration-info="audit_status == 'iva'"
                           decoration-primary="audit_status == 'monto'" decoration-warning="audit_status == 'pago'"/>
                    <field name="motive"/>
                </tree>
            </field>
        </record>

        <record id="view_ticket_monitor_audit_search" model="ir.ui.view">
            <field name="name">ticket.monitor.audit.search</field>
            <field name="model">contabilidad_kuale.ticket_monitor_audit</field>
            <field name="arch" type="xml">
                <search string="Buscar Auditoría de Tickets">
                    <field name="ticket_folio"/>
                    <field name="date"/>
                    <field name="audit_status"/>
                </search>
            </field>
        </record>

        <record id="action_ticket_monitor_audit" model="ir.actions.act_window">
            <field name="name">Monitoreo de Auditoría de Tickets</field>
            <field name="res_model">contabilidad_kuale.ticket_monitor_audit</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="view_ticket_monitor_audit_tree"/>
            <field name="search_view_id" ref="view_ticket_monitor_audit_search"/>
        </record>


    </data>
</odoo>