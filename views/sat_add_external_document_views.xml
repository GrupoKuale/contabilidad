<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- VISTA DEL WIZARD -->
    <record id="view_sat_add_external_document_wizard" model="ir.ui.view">
        <field name="name">sat.add.external.document.wizard.form</field>
        <field name="model">sat.add.external.document.wizard</field>
        <field name="arch" type="xml">
            <form string="Agregar documento al ADD">
                <group>
                    <field name="file" filename="file_name" required="1"/>
                    <field name="file_name" invisible="1"/>
                </group>
                <footer>
                    <button string="Agregar"
                            type="object"
                            name="action_create_document"
                            class="btn-primary"/>
                    <button string="Cancelar"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ACCIÓN DEL WIZARD -->
    <record id="action_sat_add_external_document_wizard" model="ir.actions.act_window">
        <field name="name">Agregar documento</field>
        <field name="res_model">sat.add.external.document.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_sat_add_external_document_wizard"/>
        <field name="target">new</field>
    </record>

    <!-- MENÚ EN SECCIÓN ADD -->
    <menuitem id="menu_sat_add_external_document"
              name="Agregar documentos"
              parent="menu_sat_add_section"
              action="action_sat_add_external_document_wizard"
              sequence="5"/>
</odoo>
