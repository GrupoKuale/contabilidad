<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="ir_cron_check_rfc_blacklist" model="ir.cron">
            <field name="name">[RFC] Verificar lista negra SAT</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model.check_rfc_blacklist_cron()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <record id="res_partner_form_view_custom" model="ir.ui.view">
            <field name="name">res.partner.form.custom</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='function']" position="after">
                    <field name="comercial_name"/>
                </xpath>
            </field>
        </record>

        <record id="res_partner_bank_form_view_custom" model="ir.ui.view">
            <field name="name">res.partner.bank.form.custom</field>
            <field name="model">res.partner.bank</field>
            <field name="inherit_id" ref="account.view_partner_bank_form_inherit_account"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='currency_id']" position="after">
                    <field name="is_default" widget="boolean_toggle"/>
                </xpath>
            </field>
        </record>
        <record id="res_partner_bank_tree_view_custom" model="ir.ui.view">
            <field name="name">res.partner.bank.tree.custom</field>
            <field name="model">res.partner.bank</field>
            <field name="inherit_id" ref="base.view_partner_bank_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='allow_out_payment']" position="after">
                    <field name="is_default" widget="boolean_toggle"/>
                </xpath>
            </field>
        </record>

        <record id="view_partner_form_checkid" model="ir.ui.view">
        <field name="name">res.partner.form.checkid</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="CheckID" name="checkid_verification">
                    <group>
                        <group>
                            <field name="rfc"/>
                            <field name="curp"/>
                            <field name="checkid_verification_count" string="Verificaciones"/>
                            <field name="checkid_last_verification"/>
                        </group>
                        <group>
                            <field name="checkid_rfc_valid"/>
                            <field name="checkid_curp_valid"/>
                            <field name="checkid_blacklist_status"/>
                        </group>
                    </group>

                    <separator string="Verificación"/>
                    <button name="action_verify_checkid" string="Verificar RFC/CURP" type="object" class="btn-primary"/>

                    <separator string="Historial de Verificaciones"/>
                    <field name="checkid_verification_ids" nolabel="1">
                        <tree>
                            <field name="verification_date"/>
                            <field name="search_term"/>
                            <field name="verification_type"/>
                            <field name="rfc_exitoso" string="RFC OK"/>
                            <field name="curp_exitoso" string="CURP OK"/>
                            <field name="estado_69_con_problema" string="Lista Negra SAT" widget="boolean_toggle"/>
                        </tree>
                        <form>
                            <sheet>
                                <h1><field name="verification_date"/></h1>
                                <group>
                                    <group>
                                        <field name="search_term"/>
                                        <field name="verification_type"/>
                                    </group>
                                    <group>
                                        <field name="rfc_exitoso"/>
                                        <field name="curp_exitoso"/>
                                        <field name="estado_69_con_problema"/>
                                    </group>
                                </group>
                                <notebook>
                                    <page string="Datos RFC" invisible="not rfc_exitoso">
                                        <group>
                                            <field name="rfc_valido"/>
                                            <field name="rfc_encontrado"/>
                                            <field name="razon_social"/>
                                            <field name="rfc_valido_hasta"/>
                                        </group>
                                    </page>
                                    <page string="Datos CURP" invisible="not curp_exitoso">
                                        <group>
                                            <field name="curp_encontrado"/>
                                            <field name="nombres"/>
                                            <field name="primer_apellido"/>
                                            <field name="segundo_apellido"/>
                                            <field name="fecha_nacimiento"/>
                                            <field name="sexo"/>
                                        </group>
                                    </page>
                                </notebook>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    </data>
</odoo>