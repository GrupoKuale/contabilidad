<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record id="view_purchase_order_line_tree_custom" model="ir.ui.view">
            <field name="name">purchase.order.line.tree.custom</field>
            <field name="model">purchase.order.line</field>
            <field name="inherit_id" ref="purchase.purchase_order_line_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='product_id']" position="after">
                    <field name="expense_center" optional="hide"/>
                    <field name="branch_split_ids" optional="hide"/>
                </xpath>
                <xpath expr="//field[@name='price_unit']" position="before">
                    <field name="price_per_pack"/>
                </xpath>
                <xpath expr="//field[@name='price_subtotal']" position="after">
                    <field name="xml_description"/>
                </xpath>

            </field>
        </record>

        <record id="view_purchase_order_form_custom" model="ir.ui.view">
            <field name="name">purchase.order.form.custom</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">

                <!-- Smart Button Pre-Póliza -->
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_pre_policy" type="object"
                            class="oe_stat_button" icon="fa-book"
                            invisible="not pre_policy_id">
                        <div class="o_stat_info">
                            <span class="o_stat_text">Pre-Póliza</span>
                            <field name="pre_policy_id" widget="many2one" readonly="1" nolabel="1"/>
                        </div>
                    </button>
                </xpath>




                <!-- Campos invisibles (necesarios para cálculos) -->
                <xpath expr="//field[@name='state']" position="before">
                    <field name="approval_level" invisible="1"/>
                    <field name="can_approve" invisible="1"/>
                    <field name="requires_authorization" invisible="1"/>
                    <field name="pre_policy_id" invisible="1"/>
                    <field name="picking_ids" invisible="1"/> 
                </xpath>

                <!-- STATUSBAR DINÁMICO -->
                <xpath expr="//header/field[@name='state']" position="replace">
                    <!-- Statusbar NORMAL (sin aprobaciones) -->
                    <!-- CORRECTO: Statusbar SIEMPRE visible según requires_authorization -->
                    <field name="state" widget="statusbar" 
                        statusbar_visible="draft,sent,purchase"
                        invisible="requires_authorization"/>

                    <!-- Statusbar de aprobaciones (SIEMPRE visible si requires_authorization) -->
                    <field name="approval_level" widget="statusbar" 
                        statusbar_visible="4,3,2,1,done"
                        invisible="not requires_authorization"
                        readonly="1"/>

                </xpath>

                <!-- BOTONES EN HEADER -->
                <xpath expr="//header" position="inside">

                    <!-- 1. Solicitar Autorización -->
                    <button name="action_request_approval" type="object"
                            string="Solicitar Autorización"
                            class="oe_highlight"
                            invisible="not requires_authorization or state not in ('draft', 'sent') or approval_level"
                            data-hotkey="a"/>

                    <!-- 2. Aprobar Orden -->
                    <button name="action_approve" type="object"
                            string="Aprobar Orden"
                            class="oe_highlight btn-success"
                            invisible="not can_approve or state != 'to_approve'"/>

                    <!-- 3. Ver Pre-Póliza (siempre visible si existe) -->
                    <button name="action_view_pre_policy" type="object"
                            string="Ver Pre-Póliza"
                            class="btn-secondary"
                            invisible="not pre_policy_id"/>

                </xpath>



                <!-- BOTÓN CONFIRMAR ORDEN -->
                <xpath expr="//button[@name='button_confirm']" position="attributes">
                    <attribute name="invisible">(requires_authorization and approval_level != 'done') or state in ('purchase', 'approved', 'done', 'cancel')</attribute>
                </xpath>


                <xpath expr="//button[@name='action_view_picking']" position="attributes">
                    <attribute name="invisible">state not in ('purchase', 'approved', 'done') or not picking_ids</attribute>
                </xpath>



                <!-- Esconder el botón SIN clase (secundario) -->
                <xpath expr="//button[@name='button_confirm' and not(@class)]" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <!-- BANNER INFORMATIVO -->
                <xpath expr="//header" position="after">
                    <!-- Banner: Esperando Solicitud de Aprobación -->
                    <div class="alert alert-warning text-center" role="alert"
                        invisible="not requires_authorization or approval_level or state != 'draft'">
                        <i class="fa fa-exclamation-triangle"/> 
                        <strong>Acción Requerida</strong><br/>
                        Esta orden requiere autorización. Haz clic en 
                        <strong>"Solicitar Autorización"</strong> para iniciar el flujo de niveles.
                    </div>
                    
                    <!-- Banner: En Proceso de Aprobación -->
                    <div class="alert alert-info text-center" role="alert"
                        invisible="state != 'to_approve' or not approval_level">
                        <i class="fa fa-info-circle"/> 
                        <strong>Proceso de Aprobación Activo</strong><br/>
                        Nivel actual requerido: 
                        <field name="approval_level" readonly="1" nolabel="1" class="oe_inline font-weight-bold"/>
                    </div>

                    <div class="alert alert-success text-center" role="alert"
                        invisible="state != 'approved'">
                        <i class="fa fa-check-circle"/> 
                        <strong>Productos Recibidos - Lista para Facturar</strong><br/>
                        Todos los productos han sido recibidos. Puedes registrar la factura del proveedor.
                    </div>
                </xpath>

                <!-- BOTÓN CREAR FACTURA DE PROVEEDOR -->
                <xpath expr="//button[@name='action_create_invoice']" position="attributes">
                    <attribute name="name">action_open_accounting_policy</attribute>
                    <attribute name="string">Abrir Póliza Contable</attribute>
                    <attribute name="invisible">state != 'approved' or not pre_policy_id</attribute>
                    <attribute name="icon">fa-book</attribute>
                </xpath>




                <!-- LO COMENTADO DESHABILITA LA VISTA POR DEFECTO DEL MODULO DE COMPRA -->
                <!--
                                <xpath expr="//group" position="attributes">
                                    <attribute name="invisible">1</attribute>
