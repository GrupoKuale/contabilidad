    <record id="view_santander_bank_statement_tree" model="ir.ui.view">
        <field name="name">santander.bank.statement.tree</field>
        <field name="model">santander.bank.statement</field>
        <field name="arch" type="xml">
            <tree string="Extractos Bancarios"
                  decoration-success="procesado == 'procesado'">
                <field name="fecha_movimiento"/>
                <field name="numero_cuenta"/>
                <field name="signo" widget="badge"
                       decoration-success="signo == '+'"
                       decoration-danger="signo == '-'"/>
                <field name="importe" sum="Total"/>
                <field name="currency_id" optional="show"/>
                <field name="descripcion"/>
                <field name="nombre_beneficiario"/>
                <field name="nombre_ordenante"/>
                <field name="banco_participante"/>
                <field name="formato_origen"/>
                <field name="procesado" widget="badge"/>
                <field name="referencia" optional="hide"/>
                <field name="clave_rastreo" optional="hide"/>
                <!-- Campos para funcionalidad básica -->
                <field name="codigo_devolucion" column_invisible="1"/>
                <field name="hora_movimiento" optional="hide"/>
                <field name="saldo" optional="hide"/>
                <field name="sucursal" optional="hide"/>
                <field name="clacon" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_santander_bank_statement_form" model="ir.ui.view">
        <field name="name">santander.bank.statement.form</field>
        <field name="model">santander.bank.statement</field>
        <field name="arch" type="xml">
            <form string="Movimiento Bancario">
                <header>
                    <button name="toggle_procesado" string="Marcar Procesado" type="object"
                            class="btn-primary" invisible="procesado == 'procesado'"/>
                    <button name="toggle_procesado" string="Marcar Pendiente" type="object"
                            class="btn-secondary" invisible="procesado == 'pendiente'"/>
                    <field name="procesado" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="numero_cuenta" class="oe_edit_only"/>
                        <h1><field name="numero_cuenta"/></h1>
                        <h2>
                            <field name="signo" widget="badge"
                                   decoration-success="signo == '+'"
                                   decoration-danger="signo == '-'"/>
                            <field name="importe" widget="monetary"/>
                            <field name="currency_id"/>
                        </h2>
                    </div>

                    <group>
                        <group string="Información Básica">
                            <field name="fecha_movimiento"/>
                            <field name="hora_movimiento"/>
                            <field name="saldo"/>
                            <field name="referencia"/>
                            <field name="sucursal"/>
                            <field name="clacon"/>
                        </group>
                        <group string="Metadatos">
                            <field name="formato_origen" readonly="1"/>
                            <field name="fecha_importacion" readonly="1"/>
                            <field name="archivo_origen" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Descripción" name="descripcion">
                            <group>
                                <field name="descripcion" colspan="2"/>
                                <field name="concepto" colspan="2"/>
                                <field name="informacion_adicional" colspan="2"/>
                                <field name="campo_afil" colspan="2"/>
                            </group>
                        </page>

                        <page string="SPEI - Beneficiario" name="beneficiario">
                            <group>
                                <group string="Datos del Beneficiario">
                                    <field name="nombre_beneficiario"/>
                                    <field name="clabe_beneficiario"/>
                                    <field name="rfc_receptor"/>
                                </group>
                                <group string="Datos del Ordenante">
                                    <field name="nombre_ordenante"/>
                                    <field name="cuenta_ordenante"/>
                                    <field name="rfc_ordenante"/>
                                </group>
                            </group>
                            <group string="Información Bancaria">
                                <field name="banco_participante" colspan="2"/>
                                <field name="clave_rastreo" colspan="2"/>
                            </group>
                        </page>

                        <page string="Devoluciones" name="devoluciones">
                            <group>
                                <field name="codigo_devolucion"/>
                                <field name="causa_devolucion" colspan="2"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_santander_bank_statement_search" model="ir.ui.view">
        <field name="name">santander.bank.statement.search</field>
        <field name="model">santander.bank.statement</field>
        <field name="arch" type="xml">
            <search string="Buscar Movimientos">
                <field name="numero_cuenta"/>
                <field name="descripcion"/>
                <field name="nombre_beneficiario"/>
                <field name="nombre_ordenante"/>
                <field name="banco_participante"/>
                <field name="referencia"/>

                <separator/>

                <filter string="Pendientes" name="pendientes"
                        domain="[('procesado','=','pendiente')]"/>
                <filter string="Procesados" name="procesados"
                        domain="[('procesado','=','procesado')]"/>

                <separator/>

                <filter name="currency_mxn"
                        string=" MXN (Pesos)"
                        domain="[('currency_id.name', '=', 'MXN')]"/>
                <filter name="currency_usd"
                        string=" USD (Dólares)"
                        domain="[('currency_id.name', '=', 'USD')]"/>
                <separator/>

                <filter string="Abonos" name="abonos"
                        domain="[('signo','=','+')]"/>
                <filter string="Cargos" name="cargos"
                        domain="[('signo','=','-')]"/>

                <separator/>

                <filter string="Transferencias SPEI" name="spei"
                        domain="[('descripcion','ilike','SPEI')]"/>
                <filter string="Con Devoluciones" name="devoluciones"
                        domain="[('codigo_devolucion','!=',False),('codigo_devolucion','!=','')]"/>

                <separator/>

                <!-- Filtros por banco -->
                <filter string="Santander" name="santander"
                        domain="[('formato_origen','in',['original','extendido'])]"/>
                <filter string="Banregio" name="banregio"
                        domain="[('formato_origen','=','banregio_csv')]"/>

                <separator/>

                <filter string="Hoy" name="hoy"
                        domain="[('fecha_movimiento','=',context_today())]"/>
                <filter string="Esta Semana" name="esta_semana"
                        domain="[('fecha_movimiento','&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter string="Este Mes" name="este_mes"
                        domain="[('fecha_movimiento','&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d'))]"/>

                <group expand="0" string="Agrupar por">
                    <filter name="group_fecha" string="Fecha" context="{'group_by': 'fecha_movimiento'}"/>
                    <filter name="group_cuenta" string="Cuenta" context="{'group_by': 'numero_cuenta'}"/>
                    <filter name="group_signo" string="Tipo (Abono/Cargo)" context="{'group_by': 'signo'}"/>
                    <filter name="group_banco_origen" string="Banco de Origen" context="{'group_by': 'formato_origen'}"/>
                    <filter name="group_procesado" string="Estado" context="{'group_by': 'procesado'}"/>
                </group>
            </search>
        </field>
    </record>


    <record id="action_santander_bank_statement" model="ir.actions.act_window">
        <field name="name">Extractos Bancarios</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">santander.bank.statement</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_santander_bank_statement_tree"/>
        <field name="search_view_id" ref="view_santander_bank_statement_search"/>
        <field name="context">{'search_default_pendientes': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay movimientos bancarios registrados
            </p>
            <p>
                Haga clic en "Importar Extracto" para comenzar a procesar archivos bancarios.
                Soporta extractos de Santander (TXT) y Banregio (CSV).
            </p>
        </field>
    </record>

