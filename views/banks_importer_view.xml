    <record id="view_bbva_xlsx_statement_importer_form" model="ir.ui.view">
        <field name="name">bbva.xlsx.statement.importer.form</field>
        <field name="model">bbva.xlsx.statement.importer</field>
        <field name="arch" type="xml">
            <form string="Importar Estado de Cuenta BBVA Excel">
                <group>
                    <group string="Archivo">
                        <field name="data_file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                    </group>

                    <group string="Configuración de Moneda">
                        <field name="currency_id"
                               widget="selection"
                               options="{'no_create': True, 'no_open': True}"
                               required="1"/>
                        <label for="currency_id"
                               string="Importante: Seleccione la moneda correcta"
                               class="text-muted"/>
                    </group>
                </group>

                <group>
                    <group string="Opciones de Importación">
                        <field name="numero_cuenta"
                               placeholder="Ej: 0123456789 (opcional)"/>
                        <field name="sheet_name"/>
                        <field name="skip_rows"/>
                        <field name="has_headers"/>
                    </group>
                    <group string="Ayuda" colspan="2" style="all:unset;">
                        <div class="alert alert-info" role="alert" style="white-space: normal; line-height: 1.5; padding: 10px 15px; border-radius: 8px;">
                            <strong>Formato BBVA Excel:</strong><br/>
                            • Extractos descargados de BBVA online<br/>
                            • Formato: índice, fecha, descripción, cargo, abono, saldo<br/>
                            • <strong> Seleccione la moneda correcta antes de importar</strong><br/>
                            • Los montos se guardarán en la moneda indicada<br/>
                        </div>
                    </group>
                </group>

                <footer>
                    <button name="action_import_statements"
                            string="Importar Extractos"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

