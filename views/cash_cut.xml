<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cash_cut_tree" model="ir.ui.view">
        <field name="name">cash.cut.tree</field>
        <field name="model">contabilidad_kuale.cash_cut</field>
        <field name="arch" type="xml">
            <tree string="Cortes de Caja">
                <field name="date"/>
                <field name="company_id"/>
                <field name="branch_id"/>
                <field name="cash_total"/>
                <field name="card_total"/>
                <field name="cut_total"/>
                <field name="difference"/>
            </tree>
        </field>
    </record>

    <record id="view_cash_cut_form" model="ir.ui.view">
        <field name="name">cash.cut.form</field>
        <field name="model">contabilidad_kuale.cash_cut</field>
        <field name="arch" type="xml">
            <form string="Corte de Caja">
                <sheet>
                    <group>
                        <field name="date"/>
                        <field name="company_id"/>
                        <field name="branch_id"/>
                    </group>
                    <group>
                        <field name="cash_total" readonly="1"/>
                        <field name="card_total" readonly="1"/>
                        <field name="cut_total" readonly="1"/>
                        <field name="difference" readonly="1"/>
                    </group>
                </sheet>
                <sheet>
                    <notebook>
                        <page string="Líneas de Corte">
                            <field name="cash_cut_line_ids">
                                <tree>
                                    <field name="date"/>
                                    <field name="cashier"/>
                                    <field name="manager"/>
                                    <field name="cash_total" readonly="1"/>
                                    <field name="card_total"/>
                                    <field name="total" readonly="1"/>
                                    <field name="system_total"/>
                                    <field name="difference" readonly="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cash_cut_line_form" model="ir.ui.view">
        <field name="name">cash.cut.line.form</field>
        <field name="model">contabilidad_kuale.cash_cut_line</field>
        <field name="arch" type="xml">
            <form string="Línea de Corte de Caja">
                <sheet>
                    <!-- DATOS GENERALES -->
                    <group>
                        <separator string="General"/>
                        <field name="date"/>
                        <field name="cashier"/>
                        <field name="manager"/>
                        <field name="deposit"/>
                    </group>

                    <!-- MONEDAS Y TOTALES DE DENOMINACIÓN -->
                    <group string="Detalle de efectivo" col="2">
                        <group>
                            <field name="coin_1000"/>
                            <field name="coin_500"/>
                            <field name="coin_200"/>
                            <field name="coin_100"/>
                            <field name="coin_50"/>
                            <field name="coin_20"/>
                            <field name="coin_10"/>
                            <field name="coin_5"/>
                            <field name="coin_2"/>
                            <field name="coin_1"/>
                            <field name="coin_050"/>
                            <field name="coin_010"/>
                        </group>
                        <group>
                            <field name="total_coin_1000" readonly="1"/>
                            <field name="total_coin_500" readonly="1"/>
                            <field name="total_coin_200" readonly="1"/>
                            <field name="total_coin_100" readonly="1"/>
                            <field name="total_coin_50" readonly="1"/>
                            <field name="total_coin_20" readonly="1"/>
                            <field name="total_coin_10" readonly="1"/>
                            <field name="total_coin_5" readonly="1"/>
                            <field name="total_coin_2" readonly="1"/>
                            <field name="total_coin_1" readonly="1"/>
                            <field name="total_coin_050" readonly="1"/>
                            <field name="total_coin_010" readonly="1"/>
                        </group>
                    </group>

                    <!-- TOTALES FINALES -->
                    <group>
                        <separator string="Resumen"/>
                        <field name="cash_total" readonly="1"/>
                        <field name="card_total"/>
                        <field name="total" readonly="1"/>
                        <field name="system_total"/>
                        <field name="difference" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cash_cut_search" model="ir.ui.view">
        <field name="name">cash.cut.search</field>
        <field name="model">contabilidad_kuale.cash_cut</field>
        <field name="arch" type="xml">
            <search string="Buscar Cortes de Caja">
                <field name="date"/>
                <field name="company_id"/>
                <field name="branch_id"/>
                <filter name="today" string="Hoy" domain="[('date', '=', context_today())]"/>
                <group expand="1" string="Agrupar por">
                    <filter name="group_by_company" string="Empresa" context="{'group_by': 'company_id'}"/>
                    <filter name="group_by_branch" string="Sucursal" context="{'group_by': 'branch_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_cash_cut" model="ir.actions.act_window">
        <field name="name">Cortes de Caja</field>
        <field name="res_model">contabilidad_kuale.cash_cut</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Registra aquí tus cortes de caja.
            </p>
        </field>
    </record>


</odoo>
