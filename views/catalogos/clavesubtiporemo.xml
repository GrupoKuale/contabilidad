<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    
        <record id="view_clavesubtiporemo_filter" model="ir.ui.view">
            <field name="name">filtro.clavesubtiporemo</field>
            <field name="model">cfdi.clavesubtiporemo</field>
            <field name="priority" eval="1"/>
            <field name="arch" type="xml">
                <search string="Buscan en todo">
                    <field name="Clave_subtiporemo" string="Todo" filter_domain="['|',('Clave_subtiporemo','ilike',self),
                              ('Nombre_remolque','ilike',self)]"/>
                </search>
            </field>
        </record>

        <record id="clavesubtiporemo_view_form" model="ir.ui.view">
            <field name="name">clavesubtiporemo form</field>
            <field name="model">cfdi.clavesubtiporemo</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="Clave_subtiporemo"/>
                            <field name="Nombre_remolque"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="clavesubtiporemo_view_tree" model="ir.ui.view">
            <field name="name">clavesubtiporemo tree</field>
            <field name="model">cfdi.clavesubtiporemo</field>
            <field name="arch" type="xml">
                <tree class="text-center" default_order='Clave_subtiporemo asc'  >
                    <field name="Clave_subtiporemo"/>
                    <field name="Nombre_remolque"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_cfdi_clavesubtiporemo">
            <field name="name">clavesubtiporemo</field>
            <field name="res_model">cfdi.clavesubtiporemo</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
