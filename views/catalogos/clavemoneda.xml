<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    
        <record id="view_clavemoneda_filter" model="ir.ui.view">
            <field name="name">filtro.clavemoneda</field>
            <field name="model">cfdi.clavemoneda</field>
            <field name="priority" eval="1"/>
            <field name="arch" type="xml">
                <search string="Buscar en todo">
                    <field name="Clave_moneda" string="Todo" filter_domain="['|',('Clave_moneda','ilike',self),
                              ('Descripcion','ilike',self)]"/>
                </search>
            </field>
        </record>

        <record id="clavemoneda_view_form" model="ir.ui.view">
            <field name="name">clavemoneda form</field>
            <field name="model">cfdi.clavemoneda</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="Clave_moneda"/>
                            <field name="Descripcion"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="clavemoneda_view_tree" model="ir.ui.view">
            <field name="name">clavemoneda tree</field>
            <field name="model">cfdi.clavemoneda</field>
            <field name="arch" type="xml">
                <tree class="text-center" default_order='Clave_moneda asc'  >
                    <field name="Clave_moneda"/>
                    <field name="Descripcion"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_cfdi_clavemoneda">
            <field name="name">clavemoneda</field>
            <field name="res_model">cfdi.clavemoneda</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
