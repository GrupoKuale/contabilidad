<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    
        <record id="view_claveusocfdi_filter" model="ir.ui.view">
            <field name="name">filtro.claveusocfdi</field>
            <field name="model">cfdi.claveusocfdi</field>
            <field name="priority" eval="1"/>
            <field name="arch" type="xml">
                <search string="Buscar en todo">
                    <field name="Clave_UsoCFDI" string="Todo" filter_domain="['|',('Clave_UsoCFDI','ilike',self),
                              ('Descripcion','ilike',self)]"/>
                </search>
            </field>
        </record>

        <record id="claveusocfdi_view_form" model="ir.ui.view">
            <field name="name">claveusocfdi form</field>
            <field name="model">cfdi.claveusocfdi</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="Clave_UsoCFDI"/>
                            <field name="Descripcion"/>
                            <field name="Fisica"/>
                            <field name="Moral"/>
                            <field name="Regimen_fiscal_receptor"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="claveusocfdi_view_tree" model="ir.ui.view">
            <field name="name">claveusocfdi tree</field>
            <field name="model">cfdi.claveusocfdi</field>
            <field name="arch" type="xml">
                <tree class="text-center" default_order='Clave_UsoCFDI asc'  >
                    <field name="Clave_UsoCFDI"/>
                    <field name="Descripcion"/>
                    <field name="Fisica"/>
                    <field name="Moral"/>
                    <field name="Regimen_fiscal_receptor"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_cfdi_claveusocfdi">
            <field name="name">claveusocfdi</field>
            <field name="res_model">cfdi.claveusocfdi</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
