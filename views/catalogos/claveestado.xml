<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    
        <record id="view_claveestado_filter" model="ir.ui.view">
            <field name="name">filtro.claveestado</field>
            <field name="model">cfdi.claveestado</field>
            <field name="priority" eval="1"/>
            <field name="arch" type="xml">
                <search string="Buscar en todo">
                    <field name="Clave_estado" string="Todo" filter_domain="['|',('Clave_estado','ilike',self),
                              '|',('Clave_pais','ilike',self),
                              ('Nombre','ilike',self)]"/>
                </search>
            </field>
        </record>

        <record id="claveestado_view_form" model="ir.ui.view">
            <field name="name">claveestado form</field>
            <field name="model">cfdi.claveestado</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="Clave_estado"/>
                            <field name="Clave_pais"/>
                            <field name="Nombre"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="claveestado_view_tree" model="ir.ui.view">
            <field name="name">claveestado tree</field>
            <field name="model">cfdi.claveestado</field>
            <field name="arch" type="xml">
                <tree class="text-center" default_order='Clave_estado asc'  >
                    <field name="Clave_estado"/>
                    <field name="Clave_pais"/>
                    <field name="Nombre"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_cfdi_claveestado">
            <field name="name">claveestado</field>
            <field name="res_model">cfdi.claveestado</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
