<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    
        <record id="view_clavemetododepago_filter" model="ir.ui.view">
            <field name="name">filtro.clavemetododepago</field>
            <field name="model">cfdi.clavemetododepago</field>
            <field name="priority" eval="1"/>
            <field name="arch" type="xml">
                <search string="Buscar en todo">
                    <field name="Clave_metodo_de_pago" string="Todo" filter_domain="['|',('Clave_metodo_de_pago','ilike',self),
                              ('Descripcion','ilike',self)]"/>
                </search>
            </field>
        </record>

        <record id="clavemetododepago_view_form" model="ir.ui.view">
            <field name="name">clavemetododepago form</field>
            <field name="model">cfdi.clavemetododepago</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="Clave_metodo_de_pago"/>
                            <field name="Descripcion"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="clavemetododepago_view_tree" model="ir.ui.view">
            <field name="name">clavemetododepago tree</field>
            <field name="model">cfdi.clavemetododepago</field>
            <field name="arch" type="xml">
                <tree class="text-center" default_order='Clave_metodo_de_pago asc'  >
                    <field name="Clave_metodo_de_pago"/>
                    <field name="Descripcion"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_cfdi_clavemetododepago">
            <field name="name">clavemetododepago</field>
            <field name="res_model">cfdi.clavemetododepago</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
