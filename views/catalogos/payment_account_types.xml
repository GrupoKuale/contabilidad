<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista Tree -->
    <record id="view_payment_account_types_tree" model="ir.ui.view">
        <field name="name">payment.account.types.tree</field>
        <field name="model">payment.account.types</field>
        <field name="arch" type="xml">
            <tree string="Tipos de Cuenta de Pago">
                <field name="account"/>
                <field name="account_concept"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- Vista Form -->
    <record id="view_payment_account_types_form" model="ir.ui.view">
        <field name="name">payment.account.types.form</field>
        <field name="model">payment.account.types</field>
        <field name="arch" type="xml">
            <form string="Tipo de Cuenta de Pago">
                <sheet>
                    <group>
                        <group>
                        <field name="account"/>
                        <field name="account_concept"/>
                        </group>
                        <group>
                        <field name="active" widget="boolean_toggle"/>
                        <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_payment_account_types_search" model="ir.ui.view">
        <field name="name">payment.account.types.search</field>
        <field name="model">payment.account.types</field>
        <field name="arch" type="xml">
            <search string="Buscar Tipo de Cuenta">
                <field name="account"/>
                <field name="account_concept"/>
                <filter string="Activos" name="filter_active" domain="[('active','=',True)]"/>
                <filter string="Inactivos" name="filter_inactive" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_payment_account_types" model="ir.actions.act_window">
        <field name="name">Tipos de Cuenta</field>
        <field name="res_model">payment.account.types</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_payment_account_types_search"/>
    </record>


</odoo>
