<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    
        <record id="view_claveimpuesto_filter" model="ir.ui.view">
            <field name="name">filtro.claveimpuesto</field>
            <field name="model">cfdi.claveimpuesto</field>
            <field name="priority" eval="1"/>
            <field name="arch" type="xml">
                <search string="Buscar en todo">
                    <field name="Clave_impuesto" string="Todo" filter_domain="['|',('Clave_impuesto','ilike',self),
                              ('Descripcion','ilike',self)]"/>
                </search>
            </field>
        </record>

        <record id="claveimpuesto_view_form" model="ir.ui.view">
            <field name="name">claveimpuesto form</field>
            <field name="model">cfdi.claveimpuesto</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="Clave_impuesto"/>
                            <field name="Descripcion"/>
                            <field name="Retencion"/>
                            <field name="Traslado"/>
                            <field name="Local_Federal"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="claveimpuesto_view_tree" model="ir.ui.view">
            <field name="name">claveimpuesto tree</field>
            <field name="model">cfdi.claveimpuesto</field>
            <field name="arch" type="xml">
                <tree class="text-center" default_order='Clave_impuesto asc'  >
                    <field name="Clave_impuesto"/>
                    <field name="Descripcion"/>
                    <field name="Retencion"/>
                    <field name="Traslado"/>
                    <field name="Local_Federal"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_cfdi_claveimpuesto">
            <field name="name">claveimpuesto</field>
            <field name="res_model">cfdi.claveimpuesto</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
