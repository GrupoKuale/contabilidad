<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    
        <record id="view_claveconfigauto_filter" model="ir.ui.view">
            <field name="name">filtro.claveconfigauto</field>
            <field name="model">cfdi.claveconfigauto</field>
            <field name="priority" eval="1"/>
            <field name="arch" type="xml">
                <search string="Buscar en todo">
                    <field name="Clave_configauto" string="Todo" filter_domain="['|',('Clave_configauto','ilike',self),
                              '|',('Descripcion','ilike',self),
                              '|',('Numero_ejes','ilike',self),
                              ('Numero_llantas','ilike',self)]"/>
                </search>
            </field>
        </record>

        <record id="claveconfigauto_view_form" model="ir.ui.view">
            <field name="name">claveconfigauto form</field>
            <field name="model">cfdi.claveconfigauto</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="Clave_configauto"/>
                            <field name="Descripcion"/>
                            <field name="Clave_configauto"/>
                            <field name="Numero_llantas"/>
                            <field name="Remolque"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="claveconfigauto_view_tree" model="ir.ui.view">
            <field name="name">claveconfigauto tree</field>
            <field name="model">cfdi.claveconfigauto</field>
            <field name="arch" type="xml">
                <tree class="text-center" default_order='Clave_configauto asc'  >
                    <field name="Clave_configauto"/>
                    <field name="Descripcion"/>
                    <field name="Clave_configauto"/>
                    <field name="Numero_llantas"/>
                    <field name="Remolque"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_cfdi_claveconfigauto">
            <field name="name">claveconfigauto</field>
            <field name="res_model">cfdi.claveconfigauto</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
