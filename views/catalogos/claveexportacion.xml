<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    
        <record id="view_claveexportacion_filter" model="ir.ui.view">
            <field name="name">filtro.claveexportacion</field>
            <field name="model">cfdi.claveexportacion</field>
            <field name="priority" eval="1"/>
            <field name="arch" type="xml">
                <search string="Buscar en todo">
                    <field name="Clave_exportacion" string="Todo" filter_domain="['|',('Clave_exportacion','ilike',self),
                              ('Descripcion','ilike',self)]"/>
                </search>
            </field>
        </record>

        <record id="claveexportacion_view_form" model="ir.ui.view">
            <field name="name">claveexportacion form</field>
            <field name="model">cfdi.claveexportacion</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="Clave_exportacion"/>
                            <field name="Descripcion"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="claveexportacion_view_tree" model="ir.ui.view">
            <field name="name">claveexportacion tree</field>
            <field name="model">cfdi.claveexportacion</field>
            <field name="arch" type="xml">
                <tree class="text-center" default_order='Clave_exportacion asc'  >
                    <field name="Clave_exportacion"/>
                    <field name="Descripcion"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_cfdi_claveexportacion">
            <field name="name">claveexportacion</field>
            <field name="res_model">cfdi.claveexportacion</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
