<odoo>
    <record id="view_sales_system_summary_tree" model="ir.ui.view">
        <field name="name">contabilidad_kuale.sales_system_summary.tree</field>
        <field name="model">contabilidad_kuale.sales_system_summary</field>
        <field name="arch" type="xml">
            <tree>
                <header>
                    <button name="%(action_sales_summary_report_wizard)d" display="always" string="Generar Reporte"
                            type="action" icon="fa-print"/>
                </header>
                <field name="company_id"/>
                <field name="date"/>
                <field name="gross_sale"/>
                <field name="discount"/>
                <field name="net_sale"/>
                <field name="tax_iva"/>
                <field name="sale_status" widget="badge" decoration-success="sale_status == 'concil'"
                       decoration-info="sale_status == 'no_concil'"/>
            </tree>
        </field>
    </record>

    <record id="view_sales_system_summary_graph" model="ir.ui.view">
        <field name="name">contabilidad_kuale.sales_system_summary.graph</field>
        <field name="model">contabilidad_kuale.sales_system_summary</field>
        <field name="arch" type="xml">
            <graph>
                <field name="date"/>
                <field name="gross_sale"/>
                <field name="net_sale"/>
                <field name="tax_iva"/>
            </graph>
        </field>
    </record>

    <record id="view_sales_system_summary_form" model="ir.ui.view">
        <field name="name">contabilidad_kuale.sales_system_summary.form</field>
        <field name="model">contabilidad_kuale.sales_system_summary</field>
        <field name="arch" type="xml">
            <form string="Resumen de Ventas">
                <header>
                    <field name="sale_status" widget="statusbar" statusbar_visible="no_concil,concil"/>
                    <button name="action_concil" type="object" class="btn-primary" string="Cierre de Conciliacion"
                            invisible="sale_status == 'not_concil'"/>
                    <button name="create_sell_account_move" type="object" string="Generar Póliza" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="date"/>
                            <field name="tax_iva"/>
                            <field name="merma_cash"/>
                            <field name="discount"/>
                        </group>
                        <group>
                            <field name="branch_id"/>
                            <field name="gross_sale"/>
                            <field name="net_sale"/>
                            <field name="merma_percentage"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Desglose General">
                            <field name="sales_system_summary_itemization_ids">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="amount"/>
                                    <field name="iva_amount"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Formas de Pago">
                            <field name="sales_system_summary_itemization_fp_ids">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="amount"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Cancelaciones">
                            <field name="sales_system_summary_itemization_cancellation_ids">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="amount"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Grupos">
                            <field name="sales_system_summary_itemization_groups_ids">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="amount"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Usos">
                            <field name="sales_system_summary_itemization_uses_ids">
                                <tree editable="bottom">
                                    <field name="date"/>
                                    <field name="clave"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="price_a"/>
                                    <field name="price_b"/>
                                    <field name="price_c"/>
                                    <field name="amount"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Ventas por Hora">
                            <field name="sales_system_summary_itemization_sbh_ids">
                                <tree>
                                    <field name="time_range"/>
                                    <field name="tickets_number"/>
                                    <field name="gross_sale"/>
                                    <field name="net_sale"/>
                                </tree>
                                <form>
                                    <group>
                                        <group>
                                            <field name="time_range"/>
                                            <field name="tickets_number"/>
                                        </group>
                                        <group>
                                            <field name="gross_sale"/>
                                            <field name="net_sale"/>
                                        </group>
                                    </group>
                                    <notebook>
                                        <page string="Productos">
                                            <field name="product_itemization_id">
                                                <tree editable="bottom">
                                                    <field name="product_id"/>
                                                    <field name="name"/>
                                                    <field name="qty"/>
                                                </tree>
                                            </field>
                                        </page>
                                    </notebook>
                                </form>
                            </field>
                        </page>

                        <page string="Tipo de Venta">
                            <field name="sales_system_summary_sell_types_ids">
                                <tree>
                                    <field name="sell_type"/>
                                    <field name="ticket_amount"/>
                                    <field name="gross_sale"/>
                                    <field name="net_sale"/>
                                </tree>
                                <form>
                                    <group>
                                        <group>
                                            <field name="sell_type"/>
                                            <field name="gross_sale"/>
                                        </group>
                                        <group>
                                            <field name="ticket_amount"/>
                                            <field name="net_sale"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>

                        <page string="Lectura Agua">
                            <field name="water_measurement">
                                <tree editable="bottom">
                                    <field name="day_name" optional="hide"/>
                                    <field name="day_lecture"/>
                                    <field name="day_consumption"/>
                                    <field name="lecture"/>
                                    <field name="consumption"/>
                                    <field name="price"/>
                                    <field name="water_cost"/>
                                    <field name="sewage_cost"/>
                                    <field name="total_cost"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Detalles adicionales">
                            <group>
                                <group>
                                    <field name="weather_avg"/>
                                    <field name="incidents_type"/>
                                    <field name="opportunities"/>
                                </group>
                                <group>
                                    <field name="weather_details"/>
                                    <field name="incident_details"/>
                                    <field name="opportunities_details"/>
                                </group>
                            </group>
                        </page>

                        <page string="Archivos Digitales">
                            <field name="additional_files">
                                <tree editable="bottom">
                                    <field name="file_name" string="Nombre del Archivo"/>
                                    <field name="description" string="Descripción"/>
                                    <field name="file" string="Archivo" filename="file_name" widget="download_binary"/>
                                </tree>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="file_name"/>
                                            <field name="description"/>
                                            <field name="file" filename="file_name" widget="binary"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>


                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sales_system_summary_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard de Ventas</field>
        <field name="res_model">contabilidad_kuale.sales_system_summary</field>
        <field name="view_mode">tree,form,graph</field>
        <field name="view_id" ref="view_sales_system_summary_tree"/>
        <field name="help" type="html">
            <p>Aquí puedes ver el resumen consolidado del sistema de ventas.</p>
        </field>
    </record>

    <!--CRON-->
    <record id="ir_cron_conciliate_sales_summaries" model="ir.cron">
        <field name="name">Conciliación automática por empresa y sucursal</field>
        <field name="model_id" ref="model_contabilidad_kuale_sales_system_summary"/>
        <field name="state">code</field>
        <field name="code">model.cron_conciliate_all_companies()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_type">days</field>
        <field name="interval_number">1</field>
        <field name="numbercall">-1</field>
        <field name="doall">False</field>
        <field name="active">True</field>
        <field name="nextcall"
               eval="(DateTime.now().replace(hour=23, minute=50, second=0)).strftime('%Y-%m-%d %H:%M:%S')"/>
    </record>

</odoo>
