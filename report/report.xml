<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!--    # Financial report    -->
    <record id="financial_report_pdf" model="ir.actions.report">
        <field name="name">Informes financieros</field>
        <field name="model">financial.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">contabilidad_kuale.report_financial</field>
        <field name="report_file">contabilidad_kuale.report_financial</field>
    </record>
    <!--    # General ledger report    -->
    <record id="action_report_general_ledger" model="ir.actions.report">
        <field name="name">Libro mayor general</field>
        <field name="model">account.report.general.ledger</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">contabilidad_kuale.report_general_ledger</field>
        <field name="report_file">contabilidad_kuale.report_general_ledger</field>
    </record>
    <!--    # Partner ledger report    -->
    <record id="action_report_partnerledger" model="ir.actions.report">
        <field name="name">Libro de contabilidad de socios</field>
        <field name="model">account.report.partner.ledger</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">contabilidad_kuale.report_partnerledger</field>
        <field name="report_file">contabilidad_kuale.report_partnerledger</field>
    </record>
    <!--    # Ageing report    -->
    <record id="action_report_aged_partner_balance" model="ir.actions.report">
        <field name="name">Saldo de pareja envejecida</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">contabilidad_kuale.report_agedpartnerbalance</field>
        <field name="report_file">contabilidad_kuale.report_agedpartnerbalance</field>
    </record>
    <!--    # Journal audit report    -->
    <record id="action_report_journal" model="ir.actions.report">
        <field name="name">Registros de auditoría</field>
        <field name="model">account.common.journal.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">contabilidad_kuale.report_journal_audit</field>
        <field name="report_file">contabilidad_kuale.report_journal_audit</field>
    </record>
    <!--    # Tax report    -->
    <record id="action_report_account_tax" model="ir.actions.report">
        <field name="name">Informe fiscal</field>
        <field name="model">kit.account.tax.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">contabilidad_kuale.report_tax</field>
        <field name="report_file">contabilidad_kuale.report_tax</field>
    </record>
    <!--    # Trial balance report    -->
    <record id="action_report_trial_balance" model="ir.actions.report">
        <field name="name">Balance de comprobación</field>
        <field name="model">account.balance.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">contabilidad_kuale.report_trial_balance</field>
        <field name="report_file">contabilidad_kuale.report_trial_balance</field>
    </record>
    <!--    # CAsh flow statements    -->
    <record id="action_report_cash_flow" model="ir.actions.report">
        <field name="name">Estado de flujo de efectivo</field>
        <field name="model">account.financial.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">contabilidad_kuale.report_cash_flow</field>
        <field name="report_file">contabilidad_kuale.report_cash_flow</field>
    </record>
    <!--    # Accounting Bank Book Report    -->
    <record id="action_report_bank_book" model="ir.actions.report">
        <field name="name">Informe de la libreta bancaria</field>
        <field name="model">account.bank.book.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">contabilidad_kuale.report_bank_book</field>
        <field name="report_file">contabilidad_kuale.report_bank_book</field>
        <field name="attachment_use">False</field>
    </record>

    <!--    # Accounting Cash Book Report    -->
    <record id="action_report_cash_book" model="ir.actions.report">
        <field name="name">Informe del libro de caja</field>
        <field name="model">account.cash.book.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">contabilidad_kuale.report_cash_book</field>
        <field name="report_file">contabilidad_kuale.report_cash_book</field>
        <field name="attachment_use">False</field>
    </record>

    <!--    # Accounting Day Book Report    -->
    <record id="day_book_pdf_report" model="ir.actions.report">
        <field name="name">Informe diario en formato PDF</field>
        <field name="model">account.day.book.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">contabilidad_kuale.day_book_report_template</field>
        <field name="report_file">contabilidad_kuale.day_book_report_template</field>
        <field name="attachment_use">True</field>
    </record>
</odoo>
