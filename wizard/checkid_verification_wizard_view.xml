<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_checkid_verification_wizard" model="ir.ui.view">
            <field name="name">checkid.verification.wizard.form</field>
            <field name="model">checkid.verification.wizard</field>
            <field name="arch" type="xml">
                <form string="Verificar con CheckID">
                    <sheet>
                        <div class="oe_title">
                            <h1>Verificación CheckID</h1>
                        </div>

                        <group>
                            <group>
                                <field name="partner_id" readonly="1"/>
                                <field name="search_term"/>
                                <field name="verification_type"/>
                            </group>
                        </group>

                        <separator string="Opciones de Búsqueda"/>
                        <group>
                            <group>
                                <field name="get_rfc"/>
                                <field name="get_curp"/>
                                <field name="get_69"/>
                                <field name="get_nss"/>
                            </group>
                            <group>
                                <field name="get_regimen"/>
                                <field name="get_cp"/>
                                <field name="get_weeks"/>
                            </group>
                        </group>

                        <div invisible="not verification_result">
                            <separator string="Resultado"/>
                            <field name="verification_result" widget="text" readonly="1"/>
                        </div>

                        <footer>
                            <button string="Verificar" name="action_verify" type="object" class="btn-primary"/>
                            <button string="Cancelar" special="cancel" class="btn-secondary"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Eliminación explícita de acción duplicada -->
        <delete model="ir.actions.act_window" id="action_checkid_verification_wizard" search="[('res_model', '=', 'checkid.verification.wizard')]"/>

    </data>
</odoo>