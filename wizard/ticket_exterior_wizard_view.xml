<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_ticket_exterior_wizard_form" model="ir.ui.view">
            <field name="name">ticket.exterior.wizard.form</field>
            <field name="model">contabilidad_kuale.ticket_exterior_wizard</field>
            <field name="arch" type="xml">
                <form string="Carga Timbrado Externo">
                    <field name="state" invisible="1"/>
                    
                    <sheet>
                        <group invisible="state != 'upload'">
                            <field name="file" filename="filename" widget="binary" options="{'accepted_file_extensions': '.xlsx,.xls'}"/>
                            <field name="filename" invisible="1"/>
                        </group>
                        
                        <div invisible="state != 'upload'" class="text-muted" style="margin-top: 20px;">
                            <p>Sube un archivo Excel con las siguientes columnas (se ignoran mayúsculas y espacios):</p>
                            <ul>
                                <li><strong>Sucursal</strong></li>
                                <li><strong>Número de ticket</strong></li>
                                <li><strong>Monto</strong></li>
                            </ul>
                            <p>Odoo validará que el ticket exista con el mismo monto para cambiar su estado a <b>Timbrado Externo</b>.</p>
                        </div>
                        
                        <div invisible="state != 'done'" class="w-100" style="margin-top: 10px;">
                            <field name="summary_html" nolabel="1" widget="html" readonly="1" options="{'cssReadonly': true}"/>
                        </div>
                    </sheet>
                    
                    <footer>
                        <button string="Procesar Archivo" name="action_process_file" type="object" class="btn-primary" invisible="state != 'upload'"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel" invisible="state != 'upload'"/>
                        <button string="Cerrar" class="btn-secondary" special="cancel" invisible="state != 'done'"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
