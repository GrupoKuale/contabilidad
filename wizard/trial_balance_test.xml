<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- PLAN DE CUENTAS -->

    <record id="view_kuale_trial_balance" model="ir.ui.view">
        <field name="name">account.account.kuale.trial.balance</field>
        <field name="model">account.account</field>
        <field name="arch" type="xml">
            <kuale_trial_balance/>
        </field>
    </record>

    <record id="action_kuale_trial_balance" model="ir.actions.act_window">
        <field name="name">Plan de cuentas</field>
        <field name="res_model">account.account</field>
        <field name="view_mode">search,kuale_trial_balance</field>
        <field name="view_id" ref="view_kuale_trial_balance"/>
    </record>

    <menuitem id="menu_kuale_trial_balance" name="Plan de cuentas"
              parent="account.menu_finance_reports" action="action_kuale_trial_balance" sequence="95"/>

