<odoo>
    <record id="view_sat_xml_match_wizard_form" model="ir.ui.view">
        <field name="name">sat.xml.match.wizard.form</field>
        <field name="model">sat.xml.match.wizard</field>
        <field name="arch" type="xml">
            <form string="Conciliar Productos Faltantes">
                <div class="alert alert-info" role="alert" style="margin-bottom:10px;">
                    <i class="fa fa-info-circle"/> Se encontraron conceptos sin asociación. 
                    Selecciona <b>"Crear Nuevo"</b> y asigna una categoría, o <b>"Vincular"</b> si ya existe.
                </div>
                
                <group>
                    <field name="partner_id" readonly="1"/>
                </group>

                <field name="line_ids">
                    <tree editable="bottom" create="0" delete="0">
                        <field name="xml_code" optional="show"/>
                        <field name="xml_description"/>
                        <field name="xml_price" width="80px"/>
                        
                        <field name="action_type" widget="badge" 
                               decoration-success="action_type == 'create_new'"
                               decoration-warning="action_type == 'link_existing'"/>

                        <field name="categ_id" 
                               invisible="action_type != 'create_new'"
                               required="action_type == 'create_new'"
                               placeholder="Categoría..."/>
                        
                        <field name="xml_uom_id" optional="hide"/>

                        <field name="selected_product_id" 
                               invisible="action_type != 'link_existing'"
                               required="action_type == 'link_existing'"
                               placeholder="Buscar producto..."/>

                        <button name="action_open_create_form" 
                                type="object" 
                                icon="fa-external-link" 
                                title="Abrir ficha completa del producto"
                                invisible="action_type != 'create_new'"
                                class="btn-secondary"/>
                    </tree>
                </field>

                <footer>
                    <button name="action_confirm" string="Confirmar y Procesar" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>