<odoo>
    <record id="view_sales_summary_report_wizard_form" model="ir.ui.view">
        <field name="name">sales.system.summary.report.wizard.form</field>
        <field name="model">sales.system.summary.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Generar Reporte PDF">
                <group>
                    <field name="company_id"/>
                    <field name="branch_id"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    <button name="generate_pdf_report" type="object" string="Generar PDF" class="btn-primary"/>
                    <button name="generate_xlsx_report" type="object" string="Generar Excel" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sales_summary_report_wizard" model="ir.actions.act_window">
        <field name="name">Reporte PDF</field>
        <field name="res_model">sales.system.summary.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
